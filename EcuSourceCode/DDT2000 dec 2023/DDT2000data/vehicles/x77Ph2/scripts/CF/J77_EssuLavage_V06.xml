  <featuredescription lang="fr">
    <name>ESSUYAGE et LAVAGE</name>
    <description>Ensemble de sous prestations relativent a l'essuyage avant</description>
    <description> et arriere ainsi qu'au lavage avant, arriere et des feux</description>
  </featuredescription>
  <featuredescription lang="es">
    <name>LIMPIAR y LAVARSE</name>
    <description>Essemble de contimos prestaciones relativent al enjugamiento</description>
    <description> antes y ases­ como al lavado antes, trasera y fuegos</description>
  </featuredescription>
  <featuredescription lang="en">
    <name>WIPING and WASHING</name>
    <description>Group of Sub prestation relative to the whipping of the front</description>
    <description> and rear windows and the washing of the front, rear windows and ligths</description>
  </featuredescription>
  <feature id="AutomaticWindScreenWipping">
    <featuredescription lang="fr">
      <name>Essuyage automatic avant</name>
      <description>Declenchement des essuie vitre avant realise</description>
      <description> par une demande du capteur de pluie. Le vehicule doit</description>
      <description> en etre equipe et configure pour utiliser le capteur de pluie.</description>
    </featuredescription>
    <featuredescription lang="en">
      <name>AUTOMATIC FRONT WIPPING</name>
      <description> Front Wipper Activation on rainsensor request.</description>
      <description> the vehicle muste be equiped wtih the rain sensor,</description>
      <description> and have it activated. It should also be configured for it.</description>
    </featuredescription>
    <featuredescription lang="es">
      <name>ENJUGAMIENTO AUTOMATICO PONE CRISTALES ANTES</name>
      <description>Declenchement seca(sufre) cristal antes de(antes)</description>
      <description> realizado por una peticion del captador de lluvia.</description>
      <description> El vehicule lo debe etre equipado y configurar para</description>
      <description> utilizado al captador de lluvia.</description>
    </featuredescription>
    <use diagitem="FrontFixedStopPositionInfo" as="input" />
    <use diagitem="FrontAndRearStopPositionSensor" as="input" />
    <use diagitem="RainSensor" as="input" />
    <use diagitem="WipeByRainSensor" as="input" />
    <use diagitem="CombiSwitchWipper" as="input" />
    <use diagitem="RelaySelectionSpeedForFrontWipperMotor" as="output" />
  </feature>
  <feature id="AutomaticRearWindowWipping">
    <featuredescription lang="fr">
      <name>Essuyage automatic arriere</name>
      <description>Active sur detection Marche arriere, capteur pluie et Lavage lunette</description>
    </featuredescription>
    <featuredescription lang="en">
      <name>AUTOMATIC REAR WIPPING</name>
      <description>Wipper Activation on rain detection or washing phase Rear gear engaged </description>
    </featuredescription>
    <featuredescription lang="es">
      <name>ENJUGAMIENTO AUTOMATICO CRISTAL TRASERO</name>
      <description>Activa sobre detection Marca arriere, captador lluvia y Lavado anteojo</description>
    </featuredescription>
    <use diagitem="RearGearDetection" as="input" />
    <use diagitem="RainSensor" as="input" />
    <use diagitem="WipeByRainSensor" as="input" />
    <use diagitem="CombiSwitchWipper" as="input" />
    <use diagitem="RearFixedStopPositionInfo" as="input" />
    <use diagitem="FrontAndRearStopPositionSensor" as="input" />
    <use diagitem="RearWipperMotor" as="output" />
  </feature>
  <feature id="WindScreenManualWipping">
    <featuredescription lang="fr">
      <name>essuyage manuel AV et AR</name>
      <description>Activation de l'essuyage avant et arriere suite</description>
      <description> a une requete via la commande sous volant realise par le conducteur</description>
    </featuredescription>
    <featuredescription lang="en">
      <name>FRONT REAR WINDOW MANUAL WIPPING</name>
      <description>Front and Rear wipping activation realised after</description>
      <description> a request via the comiswitch from the driver.</description>
    </featuredescription>
    <featuredescription lang="es">
      <name>ENJUGAMIENTO MANUAL PONE CRISTALES AVDA AR</name>
      <description>Activacien del enjugamiento antes y trasera</description>
      <description> continuaciÃƒÂ³n tiene un requete ve­a el encargo bajo</description>
      <description> volante realizado por el conductor</description>
    </featuredescription>
    <use diagitem="FrontFixedStopPositionInfo" as="input" />
    <use diagitem="FrontAndRearStopPositionSensor" as="input" />
    <use diagitem="CombiSwitchWipper" as="input" />
    <use diagitem="RelaySelectionSpeedForFrontWipperMotor" as="output" />
  </feature>
  <feature id="CleaningFrontRearWindows">
    <featuredescription lang="fr">
      <name>lavage vitre AV et AR</name>
      <description>Activation du Lavage lunette et vitre</description>
    </featuredescription>
    <featuredescription lang="en">
      <name>FRONT AND REAR WINDOS WASHING</name>
      <description>Wash front and rear windows</description>
    </featuredescription>
    <featuredescription lang="es">
      <name>LAVADO PONE CRISTALES ANTES TRASERO</name>
      <description>ActivaciÃƒÂ³n del Lavado anteojo y cristal</description>
    </featuredescription>
    <use diagitem="FrontFixedStopPositionInfo" as="input" />
    <use diagitem="FrontAndRearStopPositionSensor" as="input" />
    <use diagitem="CombiSwitchWipper" as="input" />
    <use diagitem="WashingPumpRearFrontWindow" as="output" />
    <use diagitem="RelaySelectionSpeedForFrontWipperMotor" as="output" />
  </feature>
  <feature id="CleaningFrontBeam">
    <featuredescription lang="fr">
      <name>Lavage projecteurs</name>
      <description>Activation du Lavage et essuyage des projecteur avant</description>
    </featuredescription>
    <featuredescription lang="en">
      <name>FRONT BEAM WASH</name>
      <description>Activation of Ront beam washing and whipping</description>
    </featuredescription>
    <featuredescription lang="es">
      <name>LAVADO DE LOS PROYECTORES</name>
      <description>ActivaciÃƒÂ³n del Lavado y el enjugamiento del proyector antes</description>
    </featuredescription>
    <use diagitem="WashingBeamMotorPump" as="output" />
    <use diagitem="CombiSwitchWipper" as="input" />
    <use diagitem="WashingPumpPowerSupply" as="input" />
    <featuredescription lang="ja">
      <name>アバヂエ</name>
    </featuredescription>
  </feature>
