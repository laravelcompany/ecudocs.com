<?xml version="1.0" encoding="UTF-8"?><xsl:stylesheet version="1.0"				xmlns="http://schemas.microsoft.com/intellisense/ie5"				xmlns:xsl="http://www.w3.org/1999/XSL/Transform"				xmlns:cf="http://www-diag.renault.com/2003/CustomerFeatures"				xmlns:msxsl="urn:schemas-microsoft-com:xslt"				xmlns:user="http://mycompany.com/mynamespace"><xsl:output method="html" encoding="UTF-8"/><xsl:key name="uses" match="cf:use" use="@diagitem"/><xsl:key name="items" match="cf:diagitem" use="@id"/><msxsl:script language="VBscript" implements-prefix="user" >option explicitDim SessionDim converterDim DatasDim DevicesDim DiagItemsDim DataListByDeviceByFunctionDim DataListByIdDim FoundFeaturesDim NotFoundFeatures'=====================' MATCH IMAGE function (manage color of icon for features matching)'=====================function MatchImage(nodelist)dim featureiddim nodeSet node=nodelist.nextnodefeatureid = node.getattribute("id")if FoundFeatures.exists (featureid) then	if NotFoundFeatures.exists (featureid) then		MatchImage="StatusYellow.jpg"	else		MatchImage="StatusGreen.jpg"	end ifelse	MatchImage="StatusRed.jpg"end ifend function'==================' INIT USE function (creates FoundFeatures and NotFoundFeatures dictionnaries)'==================function InitUse(nodelist)set FoundFeatures = CreateObject("Scripting.Dictionary")set NotFoundFeatures = CreateObject("Scripting.Dictionary")Dim nodeDim itemiddim featureidSet node=nodelist.nextnodedo until node Is Nothing		itemid = node.getattribute("diagitem")		featureid = node.parentnode.getattribute("id")		if diagitems.exists(itemid) then			if not FoundFeatures.exists (featureid) then FoundFeatures.Add featureid, node.parentnode		else			if not NotFoundFeatures.exists (featureid) then NotFoundFeatures.Add featureid, node.parentnode		end if	Set node=nodelist.nextnodeloopInitUse=""end function'=========================' INIT DIAG ITEMS function'=========================function InitDiagItems(nodelist)Dim DiagContextset DiagContext = createObject("DiagnosticContext.Context")Set Session = DiagContext.Objectset DiagContext = Nothingset converter = createObject("DDT2000Helper.Converter")set Datas = CreateObject("Scripting.Dictionary")set Devices = CreateObject("Scripting.Dictionary")set DataListByDeviceByFunction = CreateObject("Scripting.Dictionary")set DataListById = CreateObject("Scripting.Dictionary")set DiagItems = CreateObject("Scripting.Dictionary")Dim DataListByDeviceDim nodeDim itemidDim DataDim Devicedim nn = 0Set node=nodelist.nextnodedo until node Is Nothing		itemid = node.getattribute("id")		select case node.getattribute("type")			case "data"				n = n + 1				set data = FindData(itemid, node.selectnodes("*[local-name()='synonym']"))				If data Is Nothing Then				Else					DiagItems.Add itemid, data					Datas.Add itemid, data				End If			case "device"				set device = FindDevice(itemid, node.selectnodes("*[local-name()='synonym']"))				If device is Nothing Then				Else					DiagItems.Add itemid, device					Devices.Add itemid, device				End If		end select	Set node=nodelist.nextnodeloopDim ProtocolDim DataListDim FunctionNameDim DeviceNameDim ReturnedStringReturnedString = ""for each itemid in devices.keys	set device = devices(itemid)	Set protocol = Converter.ToDiagProtocol(device.parent)	if  DataListByDeviceByFunction.exists(protocol.FunctionName) then		set DataListByDevice = DataListByDeviceByFunction(protocol.FunctionName)	else		set DataListByDevice = CreateObject("Scripting.Dictionary")		DataListByDeviceByFunction.add protocol.FunctionName, DataListByDevice	end if	set DataList = CreateObject("Scripting.Dictionary")	DataListByDevice.add device.name, DataList	DataListById.add ItemId, DataListnextfor each itemid in datas.keys	set data = datas(itemid)	Set protocol = Converter.ToDiagProtocol(data.parent.parent)	if  DataListByDeviceByFunction.exists(protocol.FunctionName) then	else		set DataListByDevice = CreateObject("Scripting.Dictionary")		DataListByDeviceByFunction.add protocol.FunctionName, DataListByDevice	end ifnextfor each FunctionName in DataListByDeviceByFunction.keys	Set protocol = Converter.ToDiagProtocol(session(FunctionName))	for each data in protocol.DiagItems		if data.ReadOnly And Not (data.device Is Nothing) Then			set DataListByDevice = DataListByDeviceByFunction.Item(FunctionName)			DeviceName = Data.Device.Name			if DataListByDevice.exists(DeviceName) then				DataListByDevice.Item(DeviceName).add Data.Name, Data			end if		end if	NextNextfor each FunctionName in DataListByDeviceByFunction.keys	ReturnedString = ReturnedString &amp; "&#xA0;&#xA0;&#xA0;" &amp; FunctionNameNextInitDiagItems=ReturnedStringEnd function'function GetData ()'end function'===================' FIND DATA function'===================function FindData(name, names)Dim dataDim nodeset data = Nothingset data=FindReferenceData(name,"")if data is nothing then	for each node in names		set data=FindReferenceData(node.selectsinglenode("text()").nodeValue, Nothing) 'node.getattribute("address"))		if not data is nothing then exit for	nextend ifSet FindData = dataEnd function'=============================' FIND REFERENCE DATA function'=============================function FindReferenceData(name,address)Dim dataDim pDim protocolOn Error Resume Nextfor each p in Session	set data=Nothing	Set protocol = Converter.ToDiagProtocol(p)	if address is nothing then		set data=protocol.DiagItems(name)	elseif address=Cstr(protocol.address) then 		set data=protocol.DiagItems(name)	end if	if data is nothing Then		Err.Clear	else		if data.readonly Then			Exit For		Else			Set data = Nothing		End If	End IfNextErr.ClearSet FindReferenceData = dataEnd function'=====================' FIND DEVICE function'=====================function FindDevice(name, names)Dim deviceDim nodeset device = Nothingset device=FindEcuDevice(name,"")if device is nothing then	for each node in names		set device=FindEcuDevice(node.selectsinglenode("text()").nodeValue, "") ' node.getattribute("address") &amp; "" )		if not device is nothing then exit for	nextend ifSet FindDevice = deviceEnd function'=========================' FIND ECU DEVICE function'=========================function FindEcuDevice(name,address)Dim deviceDim pDim protocolset device=NothingOn Error Resume Nextfor each p in Session	Set protocol = Converter.ToDiagProtocol(p)	set device=protocol.Devices(name)	if device is nothing Then		Err.Clear	else		Exit For	End IfNextErr.ClearSet FindEcuDevice = deviceEnd FunctionFunction DataInfoForDataItem(itemid)Dim DataDim RequestDim ProtocolDim FunctionNameDim RequestNameDim DataNameDim resif Not Datas.Exists(itemid) Then	Set res = CreateObject("MSXML2.DomDocument")	Set res.documentelement=res.createelement("ddt2000data")	dim node	set node=res.CreateTextNode("no data")	res.documentelement.appendchild node	set DataInfoForDataItem=node	Exit FunctionEnd IfSet Data = Datas(itemid)DataName = data.NameSet Request = data.ParentRequestName = Request.NameSet protocol = Converter.ToDiagProtocol(Request.parent)FunctionName = protocol.FunctionNameSet res = CreateObject("MSXML2.DomDocument")Set res.documentelement=res.createelement("ddt2000data")res.documentelement.setattribute "function",FunctionNameres.documentelement.setattribute "request",RequestNameres.documentelement.setattribute "name",DataNameif not data.device Is Nothing Then	res.documentelement.setattribute "device",data.device.Nameend ifres.documentelement.setattribute "unit",data.UnitSet DataInfoForDataItem = res.documentelementEnd function'=================================' FIND INFO for DATA ITEM function'=================================Function InfoForDataItem(itemid)Dim DeviceDim ProtocolDim FunctionNameDim DeviceNameDim resFunctionName = "## NO ECU ##"DeviceName = itemidif DiagItems.Exists(itemid) Then	Set Device = DiagItems(itemid)	DeviceName = Device.Name	Set protocol = Converter.ToDiagProtocol(Device.parent.parent)	FunctionName = protocol.FunctionNameEnd IfSet res = CreateObject("MSXML2.DomDocument")Set res.documentelement=res.createelement("ddt2000device")res.documentelement.setattribute "function",FunctionNameres.documentelement.setattribute "name",DeviceNameSet InfoForDataItem = res.documentelementEnd functionFunction DiagItemExist(itemid)DiagItemExist = DiagItems.Exists(itemid)End Function'===================================' FIND INFO for DEVICE ITEM function'===================================Function InfoForDeviceItem(itemid)Dim DeviceDim ProtocolDim FunctionNameDim DeviceNameDim resFunctionName = "## NO ECU ##"DeviceName = itemidif DiagItems.Exists(itemid) Then	Set Device = DiagItems(itemid)	DeviceName = Device.Name	Set protocol = Converter.ToDiagProtocol(Device.parent)	FunctionName = protocol.FunctionNameEnd IfSet res = CreateObject("MSXML2.DomDocument")Set res.documentelement=res.createelement("ddt2000device")res.documentelement.setattribute "function",FunctionNameres.documentelement.setattribute "name",DeviceNameSet InfoForDeviceItem = res.documentelementEnd function'===========================' FIND CURRENT LANG function'===========================function CurrentLang()Dim WshShellDim BuffDim IDim langBuff=""On Error Resume NextSet WshShell = CreateObject("WScript.Shell")if Err = 0 Then	Buff = WshShell.RegRead("HKEY_CURRENT_USER\Software\Microsoft\Internet Explorer\International\AcceptLanguage")Err.Clearlang=""	I = InStr(Buff,",")	if I = 0 Then		lang = Buff	else		lang = Left(Buff, I-1)	End Ifif len(lang)=0  then	lang = "en"end ifErr.Clear	I = InStr(Lang,"-")	if I = 0 Then	else		lang = Left(lang, I-1)	End IfCurrentLang=langend functionFunction DataInfoForDeviceItems(items)Dim resDim rootDim rowDim useDim deviceidDim DeviceDim ProtocolDim deviceNameDim dataDim DataListDim DataNameSet res = CreateObject("MSXML2.DomDocument")Set root = res.createelement("xml")Set res.documentelement = rootSet use = items.nextnodedo until use Is Nothing	deviceid = use.getattribute("diagitem")	If DataListById.Exists(deviceid) Then			Set DataList = DataListById(DeviceId)		Set protocol = Converter.ToDiagProtocol(Devices(DeviceId).parent)		For each DataName in DataList.keys					set data = protocol.diagitems(DataName)					Set row = res.createelement("ddt2000data")					root.appendchild row					row.setattribute "function",protocol.FunctionName					row.setattribute "request",data.Parent.Name					row.setattribute "name",DataName					row.setattribute "device",deviceid					row.setattribute "unit",data.Unit		Next	End If	Set use = items.nextnodeLoopSet DataInfoForDeviceItems = res.documentelementEnd Function</msxsl:script><!--	========================= GENERAL DOCUMENT template =========================--><xsl:template match="/">	<html>	<head>		<meta charset="utf-8"/>		<title>Customer Features File</title>		<link rel="stylesheet" href="customerfeatures.css"/>		<script language="vbscript" src="customerfeaturesV4.vbs">		</script>	</head>			<xsl:apply-templates select="*"/>	</html></xsl:template><!--============================GENERIC DESCRIPTION template============================--><xsl:variable name="lang" select="user:CurrentLang()"/><xsl:template name="descriptions"><xsl:param name="item"/><div style="width: 100%; height: 100%; overflow: auto;"><!--- TABLE for description --><table border="0" width="100%" height="100%" cellspacing="1" cellpadding="1" style="font-family:Arial; font-size:10pt" bgcolor="#FFFFFF">	<xsl:variable name="ds" select="$item"/>	<xsl:variable name="d" select="$ds[@lang=$lang]"/>	<tr height="10" class="{$lang}" valign="top">		<td style="font-family:arial; font-size:10pt; font-weight: normal; color: black; border-bottom: 1px solid #C0C0C0;" bgcolor="ECE9D8">		<xsl:value-of select="$d/cf:name"/>&#xA0;(<xsl:value-of select="$lang"/>)		</td>	</tr>	<tr class="{$lang}" valign="top">		<td style="font-family:arial; font-size:10pt; font-weight: normal; color: black;">		<xsl:for-each select="$d/cf:description">			<xsl:value-of select="."/><br/>		</xsl:for-each>		</td>	</tr>	</table><!--- TABLE for alternate names --><table border="0" width="100%" cellspacing="0" cellpadding="0" style="font-family:Arial; font-size:10pt;" bgcolor="#F8CE84">	<tr>		<td>		<xsl:choose>		<xsl:when test="cf:synonym">			<p>Alternate names</p>			<ul>				<xsl:for-each select="cf:synonym">					<xsl:sort select="."/>					<li><xsl:value-of select="."/></li>				</xsl:for-each>			</ul>		</xsl:when>		<xsl:otherwise>			<p>No alternate names</p>		</xsl:otherwise>		</xsl:choose> 		</td>	</tr></table></div></xsl:template><!--============================GENERIC FEATURE template============================--><xsl:template match="cf:feature/@id"><xsl:variable name="name" select="../cf:featuredescription[@lang=$lang]/cf:name"/><xsl:choose><xsl:when test="$name">	<xsl:value-of select="$name/text()"/></xsl:when><xsl:otherwise>	<xsl:value-of select="."/></xsl:otherwise></xsl:choose></xsl:template><!--============================GENERIC DIAGITEM template============================--><xsl:template match="cf:diagitem/@id"><xsl:variable name="name" select="../cf:itemdescription[@lang=$lang]/cf:name"/><xsl:choose><xsl:when test="$name">	<xsl:value-of select="$name/text()"/></xsl:when><xsl:otherwise>	<xsl:value-of select="."/></xsl:otherwise></xsl:choose></xsl:template><!--=========================CUSTOMER FEATURE template=========================--><xsl:template match="cf:CustomerFeaturesdataSet"><body topmargin="0" leftmargin="0" background="picture/background.gif" scroll="auto">			<!-- MENU PAGE --><a name="TopOfPage"/><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><!-- HEADER LINE with TITLE and LANGUAGE --><tr height="35"><td width="100%"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0" style="font-family: Verdana"><tr>	<td background="picture/ChapterHeaderLeftCorner2.gif" height="35" width="28"/>	<td width="20%" background="picture/ChapterHeaderBackground.gif" height="35">		<p align="left" class="HeaderTextStyle">		&#xA0;&#xA0;		</p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35" align="center">		<p class="HeaderTextStyle"><xsl:value-of select="cf:featuredescription[@lang=$lang]/cf:name"/></p>			</td>	<td width="20%" background="picture/ChapterHeaderBackground.gif" >		<p align="right"><b>		<font face="Verdana" color="#FFFFFF" size="2"><xsl:value-of select="$lang"/>		</font></b></p>	</td>	<td background="picture/ChapterHeaderRightCorner2.gif" height="35" width="29"/></tr></table></td></tr><!-- HEADER LINE with EXIT, ECUS LIST and PAGE STATUS areas --><tr height="35"><td width="100%"><table border="0" width="100%" height="35" cellspacing="0" cellpadding="0"><tr>	<td width="10"><img border="0" src="picture/ChapterHeaderLeftCornerSmall2.gif" width="10" height="35"/></td>	<td width="12"><img border="0" src="picture/ChapterHeaderLabelLeft.gif" width="12" height="35"/></td>	<td width="60" id="ExitButton" class="ExitButtonStyle" background="picture/ChapterHeaderLabel.gif">		<p/>EXIT	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderLabelRight.gif" width="12" height="35"/></td>	<td background="picture/ChapterHeaderBackground.gif">		<p align="right"><b>		<font face="Verdana" color="#FFFFFF" size="2">managed by </font>&#xA0;		</b></p>	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderLabelLeft.gif" width="12" height="35"/></td>	<td class="ECUsListStyle" background="picture/ChapterHeaderLabel.gif" valign="middle" align="center">		<p align="center">		<xsl:value-of select="user:InitDiagItems(cf:diagitem)"/><xsl:value-of select="user:InitUse(cf:feature/cf:use)"/>&#xA0;&#xA0;&#xA0;		</p>	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderLabelRight.gif" width="12" height="35"/></td>	<td background="picture/ChapterHeaderBackground.gif">		<p align="right"><b>		<font face="Verdana" color="#FFFFFF" size="2">page status</font>		</b></p>	</td>	<td width="12" background="picture/ChapterHeaderBackground.gif"/>	<td width="12"><img border="0" src="picture/ChapterHeaderLabelLeft.gif" width="12" height="35"/></td>	<td ID="EtatPage" style="font-family: Verdana; color: red; font-size: 10pt; font-weight: bold" background="picture/ChapterHeaderLabel.gif" valign="middle" width="60" align="center">		<p align="center"/>BUSY	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderLabelRight.gif" width="12" height="35"/></td>	<td width="10"><img border="0" src="picture/ChapterHeaderRightCornerSmall2.gif" width="10" height="35"/></td></tr>	</table></td></tr><!-- ROW for auto RESIZE --><tr><td width="100%"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td background="picture/Vback.gif">		<img border="0" src="picture/Vback.gif"/>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- DETAILED FEATURES and CONTRIBUTORS --><tr height="70%"><td width="100%"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><!-- HEADERS --><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td width="5%" background="picture/Vback.gif"/>	<td background="picture/Vback.gif" align="center" width="50%">		<table border="0" width="100%" cellspacing="0" cellpadding="0" background="picture/Vback.gif">		<tr>		<td background="picture/Vback.gif" width="25">			<img border="0" src="picture/Vback.gif"/>		</td>		<td class="HomeTitleStyle">			<p/>DETAILED-FEATURES		</td>		<td background="picture/Vback.gif" width="25">			<img border="0" src="picture/Vback.gif"/>		</td>		<td background="picture/Vback.gif"/>		<td class="HomeSmallTitleStyle" width="60">			<p/>match		</td>			</tr>		</table>	</td>	<td width="5%" background="picture/Vback.gif"/>	<td class="HomeTitleStyle" background="picture/Vback.gif">		<p/>CONTRIBUTORS	</td>	<td width="5%" background="picture/Vback.gif"/>	<td width="7" background="picture/VR.gif" valign="top"/></tr><!-- DETAILED FEATURES LIST and CONTRIBTUTORS--><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td width="5%" background="picture/Vback.gif"/>		<!-- FEATURES LIST -->		<td background="picture/Vback.gif" valign="top" width="50%">		<table border="0" width="100%" cellspacing="0" cellpadding="0" background="picture/Vback.gif">		<xsl:for-each select="cf:feature">        <tr>			<td width="25" background="picture/LC.jpg" height="41">			</td>			<td background="picture/CC.jpg" height="41" style="cursor:hand" onclick="window.navigate('#Feature{@id}')">				<p class="FeaturesListStyle"/>				<xsl:apply-templates select="@id"/>			</td>			<td width="25" background="picture/RC.jpg" height="41">			</td>			<td background="picture/Vback.gif"/>			<td background="picture/{user:MatchImage(.)}" align="center" width="60" height="41"/>		</tr>				</xsl:for-each>		</table>	</td>	<td width="5%" background="picture/Vback.gif"/>			<!-- CONTRIBUTOR LIST -->	    <td class="ContributorsListDecoStyle">	<div style="width: 100%; height: 100%; overflow: auto;">		<table border="0" width="100%" cellspacing="0" cellpadding="0">		<xsl:for-each select="cf:diagitem">			<tr class="ContributorsListStyle">			<td style="cursor:hand" onclick="window.navigate('#Item{@id}')">				<a class="ContributorsListStyle"/>				<xsl:apply-templates select="@id"/>			</td>			<td>				(<xsl:value-of select="@type"/>)			</td>			</tr>		</xsl:for-each>		</table>	</div>	</td>		<td width="5%" background="picture/Vback.gif"/>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- ROW for auto RESIZE --><tr><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td background="picture/Vback.gif">		<img border="0" src="picture/Vback.gif"/>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- SEPARATION ROW --><tr  height="35"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/HMiddleLeft.gif" height="35"/>	<td background="picture/HMiddleBack.gif" height="35"/>	<td background="picture/HMiddleBack.gif" class="SeparateRowStyle" height="35">		<p/>CUSTOMER FEATURE SUMMARY	</td>	<td background="picture/HMiddleBack.gif" height="35"/>	<td width="7" background="picture/HMiddleRight.gif" valign="top" height="35"/></tr></table></td></tr><!-- DESCRIPTION --><tr height="20%"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td colspan="3" bgcolor="#D7D3CC">		<xsl:call-template name="descriptions">			<xsl:with-param name="item" select="cf:featuredescription"/>		</xsl:call-template>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- BOTTOM ROW --><tr height="33"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/HBLC.gif"/>	<td width="7" background="picture/HBL.gif" height="33"/>	<td background="picture/HBBack.gif">		<p align="center"><font color="#FFFFFF" size="1" face="Verdana">version 0.4 - (c) RENAULT 2004 All rights reserved</font></p>	</td>	<td width="7" background="picture/HBR.gif" height="33"/>	<td width="7" background="picture/HBRC.gif" valign="top"></td></tr></table></td></tr></table><!-- END of FIRST PAGE --><!-- OTHER PAGES GENERATION for FEATURES DETAILS and DIAGITEMS--><xsl:apply-templates select="cf:feature"/><xsl:apply-templates select="cf:diagitem"/></body>	</xsl:template><!--=========================FEATURES DETAILS template=========================--><xsl:template match="cf:feature">	<xsl:variable name="id" select="@id"/><br/><a name="Feature{$id}"></a><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><!-- header avec nom feature et feature label --><tr ><td width="100%"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><tr height="35">	<td background="picture/ChapterHeaderLeftCorner2.gif" height="35" width="29" style="cursor:hand" onclick="window.navigate('#Feature{$id}')"/>	<td background="picture/ChapterHeaderMenuButton.gif" height="35" width="24" style="cursor:hand" onclick="window.navigate('#TopOfPage')"/>	<td background="picture/ChapterHeaderBackground.gif" height="35" width="25%">		<p class="FeatureHeaderStyle">		&#xA0;<xsl:apply-templates select="$id"/>		</p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35">		<p class="FeatureHeaderSpecialStyle"/>&#xA0;	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderButtonLeft.gif" width="12" height="35"/></td>	<td width="10%" onclick="window.navigate('#Feature{preceding-sibling::cf:feature[1]/@id}')" class="PreviousNextStyle" background="picture/ChapterHeaderButton.gif">		<p/>PREVIOUS 	</td>	<td width="5"><img border="0" src="picture/ChapterHeaderButtonSeparator.gif" width="5" height="35"/></td>		<td width="10%" onclick="window.navigate('#Feature{following-sibling::cf:feature[1]/@id}')" class="PreviousNextStyle" background="picture/ChapterHeaderButton.gif">		<p/>NEXT	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderButtonRight.gif" width="12" height="35"/></td>		<td background="picture/ChapterHeaderBackground.gif" height="35">		<p align="center" style="color:#FFFFFF; font-family:Arial; font-size:12pt; font-weight:bold;">		&#xA0;		</p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35" width="25%">		<p class="FeatureSmallHeaderStyle"/>FEATURE	</td>	<td background="picture/ChapterHeaderRightCorner2.gif" height="35" width="29"/></tr></table></td></tr><!-- header ITEMS USED et DIAG MONITOR --><tr height="35"><td width="100%"><table border="0" width="100%" height="35" cellspacing="0" cellpadding="0"><tr>	<td width="10"><img border="0" src="picture/ChapterHeaderLeftCornerSmall2.gif" width="10" height="35"/></td>	<td background="picture/ChapterHeaderBackground.gif">		<p title="Click to show/hide details" onclick="ShowHideDetails()" class="ItemsUsedStyle"/>ITEMS USED	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35"/>	<td background="picture/ChapterHeaderBackground.gif" height="35" align="right">		<p>			<img border="0" id="ComStatus" class="ComStatusStyle" height="19" src="picture/ComOff.gif" width="105" align="middle"/>			&#xA0;&#xA0;&#xA0;		</p>		</td>	<td width="12"><img border="0" src="picture/ChapterHeaderButtonLeft.gif" width="12" height="35"/></td>	<td width="15%" onclick="StartStopMonitor()" style="font-family: Verdana; cursor:hand; color: #555555; font-size: 10pt; font-weight: bold" background="picture/ChapterHeaderButton.gif">		<p id="MonitorButton" align="center">START&#xA0;MONITOR</p>	</td>	<td width="12"><img border="0" src="picture/ChapterHeaderButtonRight.gif" width="12" height="35"/></td>	<td width="10"><img border="0" src="picture/ChapterHeaderRightCornerSmall2.gif" width="10" height="35"/></td></tr>	</table></td></tr><!-- tableau ITEMS USED --><tr height="70%"><td width="100%"><xsl:choose><xsl:when test="cf:use"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td valign="top">		<div style="width: 100%; height: 100%; overflow: auto;">		<table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0">		<tr height="20" style="font-family:arial; font-size:12pt; color: white;" >		    <td align="left" background="picture/Vback.gif">&#xA0;I/O</td>    		<td align="left" background="picture/Vback.gif">DEVICE</td>    		<td align="left" background="picture/Vback.gif">DATA</td>    		<td width="10%" align="center" background="picture/Vback.gif">MIN</td>    		<td width="10%" align="center" background="picture/Vback.gif">VALUE</td>    		<td width="10%" align="center" background="picture/Vback.gif">MAX</td>    		<td width="5%" align="center" background="picture/Vback.gif">UNIT</td>    		<td width="5%" align="center" background="picture/Vback.gif">LOCA</td>		</tr>				<!-- DEVICES -->		<xsl:for-each select="cf:use">		<xsl:sort select="@diagitem"/>		<xsl:variable name="diagitem" select="key('items',@diagitem)"/>		<xsl:variable name="type" select="$diagitem/@type"/>		<xsl:choose>			<xsl:when test="$type='device'">				<xsl:variable name="IO" select="@as"/> 			<!-- build IO variable from the DEVICE -->				<xsl:variable name="DEV" select="@diagitem"/> 	<!-- build DEV variable from the DEVICE -->				<!-- lines for all DATA linked with each DEVICE -->				<xsl:variable name="DevDataInfo" select="msxsl:node-set(user:DataInfoForDeviceItems(.))"/>				<xsl:choose>					<!-- DEVICE not found -->					<xsl:when test="count($DevDataInfo/*)=0">						<tr height="20">						<!-- COLONNE AS -->						<td class="ItemsListFirstAsStyle">							&#xA0;<xsl:value-of select="$IO"/>						</td>						<!-- COLONNE DEVICE -->						<td class="ItemsListDeviceNotFoundStyle" style="cursor:hand" onclick="window.navigate('#Item{$DEV}')">							<a id="feature{$id}item{$DEV}" class="ItemsListDeviceNotFoundStyle" >							<xsl:apply-templates select="$diagitem/@id"/>							</a>							<xsl:apply-templates select="msxsl:node-set(user:InfoForDeviceItem(string($DEV)))"/>						</td>								<!-- COLONNE DATA --> 						<td class="ItemsListStyle">							<xsl:value-of select="@name"/>						</td>						<!-- COLONNE MIN -->						<td align="center" class="ItemsListStyle">							&#xA0;						</td>						<!-- COLONNE VALUE -->						<td align="center" class="ItemsListValueStyle">							no data						</td>						<!-- COLONNE MAX -->						<td align="center" class="ItemsListStyle">						&#xA0;						</td>						<!-- COLONNE UNIT -->						<td align="center" class="ItemsListStyle">						&#xA0;<xsl:value-of select="@unit"/>						</td>						<!-- COLONNE LOCA -->						<td align="center" class="ItemsListStyle"> 						&#xA0;						</td>								</tr>					</xsl:when>					<!-- DEVICE found  -->					<xsl:otherwise>						<xsl:for-each select="$DevDataInfo/*">						<tr height="20">						<xsl:choose>							<xsl:when test="position()=1">								<!-- COLONNE AS -->								<td class="ItemsListFirstAsStyle">									&#xA0;<xsl:value-of select="$IO"/>								</td>								<!-- COLONNE DEVICE -->								<td class="ItemsListFirstDeviceStyle" style="cursor:hand" onclick="window.navigate('#Item{$DEV}')">									<a id="feature{$id}item{$DEV}" class="ItemsListDevicestyle">									<xsl:apply-templates select="$diagitem/@id"/>									</a>								<xsl:apply-templates select="msxsl:node-set(user:InfoForDeviceItem(string($DEV)))"/>								</td>								<!-- COLONNE DATA --> 								<td class="ItemsListDataFoundStyle">									<xsl:value-of select="@name"/>								</td>								<!-- COLONNE MIN -->								<td class="ItemsListStyle">									&#xA0;								</td>								<!-- COLONNE VALUE -->								<td class="ItemsListValueStyle">									<xsl:apply-templates select="."/>								</td>								<!-- COLONNE MAX -->								<td align="center" class="ItemsListStyle">									&#xA0;								</td>								<!-- COLONNE UNIT -->								<td class="ItemsListStyle">									&#xA0;<xsl:value-of select="@unit"/>								</td>								<!-- COLONNE LOCA -->								<td class="ItemsListLocaStyle"> 									<xsl:value-of select="$diagitem/@Codeloca"/>								</td>							</xsl:when>							<xsl:otherwise>								<!-- COLONNE AS -->								<td class="ItemsListAsStyle">									&#xA0;								</td>								<!-- COLONNE DEVICE -->								<td class="ItemsListDeviceStyle">									&#xA0;								</td>								<!-- COLONNE DATA --> 								<td class="ItemsListDataFoundStyle">									<xsl:value-of select="@name"/>								</td>								<!-- COLONNE MIN -->								<td class="ItemsListStyle">									&#xA0;								</td>								<!-- COLONNE VALUE -->								<td class="ItemsListValueStyle">									<xsl:apply-templates select="."/>								</td>								<!-- COLONNE MAX -->								<td class="ItemsListStyle">									&#xA0;								</td>								<!-- COLONNE UNIT -->								<td class="ItemsListStyle">									&#xA0;<xsl:value-of select="@unit"/>								</td>								<!-- COLONNE LOCA -->								<td class="ItemsListLocaStyle"> 									&#xA0;								</td>							</xsl:otherwise>						</xsl:choose>												</tr>						</xsl:for-each> 					</xsl:otherwise>				</xsl:choose>			</xsl:when>		</xsl:choose>		</xsl:for-each>								<!-- DATA -->				<xsl:for-each select="cf:use">		<xsl:sort select="@diagitem"/>		<xsl:variable name="diagitem" select="key('items',@diagitem)"/>		<xsl:variable name="type" select="$diagitem/@type"/>		<xsl:choose>		<xsl:when test="$type='data'">		<xsl:variable name="DATAINFO" select="msxsl:node-set(user:DataInfoForDataItem(string(@diagitem)))"/>				<tr height="20">			<!-- COLONNE AS -->			<td class="ItemsListFirstAsStyle">				&#xA0;<xsl:value-of select="@as"/>			</td>			<!-- COLONNE DEVICE -->			<td id="feature{$id}item{@diagitem}device" class="ItemsListDeviceFoundStyle">				<xsl:value-of select="$DATAINFO/@device"/>			</td>			<!-- COLONNE DATA -->			<td class="ItemsListDataStyle" style="cursor:hand" onclick="window.navigate('#Item{@diagitem}')">				<a id="feature{$id}item{@diagitem}" >				<xsl:attribute name="class">				<xsl:choose>					<xsl:when test="user:DiagItemExist(string(@diagitem))">ItemsListDataStyle</xsl:when>					<xsl:otherwise>ItemsListDataNOtFoundStyle</xsl:otherwise>				</xsl:choose>				</xsl:attribute>				<xsl:apply-templates select="$diagitem/@id"/>				</a>				<xsl:apply-templates select="msxsl:node-set(user:InfoForDataItem(string(@diagitem)))"/>			</td>			<!-- COLONNE MIN -->			<td class="ItemsListStyle">				<xsl:value-of select="$diagitem/@MinValue"/>			</td>			<!-- COLONNE VALUE -->			<td id="feature{$id}item{@diagitem}value" class="ItemsListValueStyle">				<xsl:apply-templates select="$DATAINFO"/>			</td>			<!-- COLONNE MAX -->			<td class="ItemsListStyle">				<xsl:value-of select="$diagitem/@MaxValue"/>			</td>			<!-- COLONNE UNIT -->			<td class="ItemsListStyle">				<xsl:value-of select="$diagitem/@Unit"/>&#xA0;			</td>			<!-- COLONNE LOCA -->			<td class="ItemsListLocaStyle"> 				<xsl:value-of select="$diagitem/@Codeloca"/>&#xA0;			</td>				</tr>		</xsl:when>		</xsl:choose>		</xsl:for-each>			<tr>		<td class="ItemsListStyle">&#xA0;</td>		<td class="ItemsListStyle">&#xA0;</td>		<td class="ItemsListStyle">&#xA0;</td>		<td class="ItemsListStyle">&#xA0;</td>		<td class="ItemsListValueStyle">&#xA0;</td>		<td class="ItemsListStyle">&#xA0;</td>		<td class="ItemsListStyle">&#xA0;</td>		<td class="ItemsListStyle">&#xA0;</td>		</tr>				</table>		</div>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></xsl:when></xsl:choose></td></tr><!-- row separation --><tr  height="35"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/HMiddleLeft.gif" height="35"/>	<td background="picture/HMiddleBack.gif" height="35"/>	<td background="picture/HMiddleBack.gif" class="SeparateRowStyle" height="35">		<p align="center"><b><font face="Verdana" color="#FFFFFF" size="2">detailed feature summary</font></b></p>		</td>	<td background="picture/HMiddleBack.gif" height="35"/>	<td width="7" background="picture/HMiddleRight.gif" valign="top" height="35"/></tr></table></td></tr><!-- row explane text --><tr height="20%"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td colspan="3" bgcolor="#D7D3CC">		<xsl:call-template name="descriptions">			<xsl:with-param name="item" select="cf:featuredescription"/>		</xsl:call-template>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- row below deco --><tr height="33"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/HBLC.gif"/>	<td width="7" background="picture/HBL.gif" height="33"/>	<td background="picture/HBBack.gif">		<p align="center"><font color="#FFFFFF" size="1" face="Verdana">(c) RENAULT 2004 All rights reserved</font></p>	</td>	<td width="7" background="picture/HBR.gif" height="33"/>	<td width="7" background="picture/HBRC.gif" valign="top"></td></tr></table></td></tr></table></xsl:template><!-- end of detailed-feature page --><!-- =========================DIAGITEM DETAILS template =========================--><xsl:template match="cf:diagitem"><xsl:variable name="id" select="@id"/><br/><a name="Item{$id}"></a><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><!-- header avec nom device/data et label --><tr><td width="100%"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><tr>	<td background="picture/ChapterHeaderLeftCorner2.gif" height="35" width="29" style="cursor:hand" onclick="window.navigate('#Item{$id}')">		<p align="center"><a>&#xA0;</a></p>	</td>	<td background="picture/ChapterHeaderMenuButton.gif" height="35" width="24" style="cursor:hand" onclick="window.navigate('#TopOfPage')">		<p align="center"><a>&#xA0;</a></p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35">		<p class="FeatureHeaderStyle">		&#xA0;<xsl:apply-templates select="$id"/>		</p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35">		<p class="FeatureHeaderSpecialStyle">		&#xA0;		</p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35">		<p class="FeatureSmallHeaderStyle">			<xsl:value-of select="@type"/>		</p>	</td>	<td background="picture/ChapterHeaderRightCorner2.gif" height="35" width="29"/></tr></table></td></tr><!-- header ITEMS USED --><tr height="35"><td width="100%"><table border="0" width="100%" height="35" cellspacing="0" cellpadding="0"><tr>	<td width="10"><img border="0" src="picture/ChapterHeaderLeftCornerSmall2.gif" width="10" height="35"/></td>	<td background="picture/ChapterHeaderBackground.gif">		<p align="left" class="ItemsUsedInStyle">		 <a>USED IN</a>		</p>	</td>	<td background="picture/ChapterHeaderBackground.gif" height="35"/>	<td width="10"><img border="0" src="picture/ChapterHeaderRightCornerSmall2.gif" width="10" height="35"/></td></tr>	</table></td></tr><!-- tableau ITEMS USED IN --><tr height="70%"><td width="100%"><table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td valign="top">		<table border="0" width="100%" height="100%" cellspacing="0" cellpadding="0" style="font-family:arial; font-size:12pt;">		<tr height="20" style="font-family:arial; font-size:12pt; color: white;" >		    <td align="left" background="picture/Vback.gif">&#xA0;FEATURES</td>    		<td align="center" background="picture/Vback.gif">AS</td>		</tr>		<xsl:choose>		<xsl:when test="key('uses',$id)">		<xsl:for-each select="key('uses',$id)">		<xsl:sort select="../@id"/>		<tr height="20">			<!-- COLONNE FEATURE -->			<td class="ItemsListDataStyle" style="cursor:hand" onclick="window.navigate('#Feature{../@id}')">				<a class="ItemsListDataStyle">&#xA0;<xsl:apply-templates select="../@id"/></a>			</td>			<!-- COLONNE AS -->			<td class="ItemsListStyle">				<xsl:value-of select="@as"/>			</td>		</tr>		</xsl:for-each>		</xsl:when>		<xsl:otherwise>		<tr height="20">			<td class="ItemsListDataStyle">				<a>&#xA0;Not used in features</a>			</td>			<td class="ItemsListDataStyle">				&#xA0;			</td>		</tr>		</xsl:otherwise>		</xsl:choose>		<tr>			<td class="ItemsListStyle">&#xA0;</td>			<td class="ItemsListStyle">&#xA0;</td>		</tr>		</table>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- row separation --><tr  height="35"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/HMiddleLeft.gif" height="35"/>	<td background="picture/HMiddleBack.gif" height="35"/>	<td background="picture/HMiddleBack.gif" class="SeparateRowStyle" height="35">		<p><xsl:value-of select="@type"/> summary</p>		</td>	<td background="picture/HMiddleBack.gif" height="35"/>	<td width="7" background="picture/HMiddleRight.gif" valign="top" height="35"/></tr></table></td></tr><!-- row explane text --><tr height="20%"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/VL.gif" valign="top"/>	<td colspan="3" bgcolor="#D7D3CC">		<xsl:call-template name="descriptions">			<xsl:with-param name="item" select="cf:itemdescription"/>		</xsl:call-template>	</td>	<td width="7" background="picture/VR.gif" valign="top"/></tr></table></td></tr><!-- row below deco --><tr height="33"><td width="100%"><table border="0" cellspacing="0" cellpadding="0" width="100%" height="100%"><tr>	<td width="7" background="picture/HBLC.gif"/>	<td width="7" background="picture/HBL.gif" height="33"/>	<td background="picture/HBBack.gif">		<p align="center"><font color="#FFFFFF" size="1" face="Verdana">(c) RENAULT 2004 All rights reserved</font></p>	</td>	<td width="7" background="picture/HBR.gif" height="33"/>	<td width="7" background="picture/HBRC.gif" valign="top"></td></tr></table></td></tr></table></xsl:template><!-- end of detailed-device/data page --><xsl:template match="ddt2000data"><object CLASSID='CLSID:DF9D14B3-D1A3-4876-88F9-017EFC197960' id="displayitems" width='100%' height='20' title="{@function} . {@name}"><param name='FontName' value='Arial Narrow'/><param name='FontSize' value='12'/><param name='CaptionWidth' value='0'/><param name='FunctionName' value='{@function}'/><param name='RequestName' value='{@request}'/><param name='DataName' value='{@name}'/><param name='DataAlignment' value='2'/><param name='Caption' value=''/></object></xsl:template><xsl:template match="ddt2000device"><span id="DiagDetail" style="display:none; font-family:Arial; font-size:8pt; color:black; background-color:#F8CE84"><br/>&#xA0;<xsl:value-of select="@function"/>&#xA0;</span><span id="DiagDetail" style="display:none; font-family:Arial; font-size:8pt; color:black; background-color:#ECE9D8">&#xA0;<xsl:value-of select="@name"/>&#xA0;</span></xsl:template></xsl:stylesheet>