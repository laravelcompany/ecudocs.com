                      <LOWER-LIMIT>250</LOWER-LIMIT>
                      <UPPER-LIMIT>254</UPPER-LIMIT>
                      <COMPU-CONST>
                        <VT>Supplier specific affectation</VT>
                      </COMPU-CONST>
                    </COMPU-SCALE>
                    <COMPU-SCALE>
                      <LOWER-LIMIT>17</LOWER-LIMIT>
                      <COMPU-CONST>
                        <VT>Control stopped by ControlOption parameter set to "Stop Control"</VT>
                      </COMPU-CONST>
                    </COMPU-SCALE>
                  </COMPU-SCALES>
                </COMPU-INTERNAL-TO-PHYS>
              </COMPU-METHOD>
