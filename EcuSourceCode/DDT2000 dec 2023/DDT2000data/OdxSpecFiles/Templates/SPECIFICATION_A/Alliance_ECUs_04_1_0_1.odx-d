                    <COMPU-SCALE>
                      <LOWER-LIMIT>18</LOWER-LIMIT>
                      <UPPER-LIMIT>249</UPPER-LIMIT>
                      <COMPU-CONST>
                        <VT>Control aborted due to internal error</VT>
                      </COMPU-CONST>
                    </COMPU-SCALE>
