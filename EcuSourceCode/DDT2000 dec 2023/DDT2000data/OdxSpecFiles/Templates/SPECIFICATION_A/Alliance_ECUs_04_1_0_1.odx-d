              <INTERNAL-CONSTR>
                <SCALE-CONSTRS>
                  <SCALE-CONSTR VALIDITY="NOT-DEFINED">
                    <LOWER-LIMIT>0</LOWER-LIMIT>
                    <UPPER-LIMIT>0</UPPER-LIMIT>
