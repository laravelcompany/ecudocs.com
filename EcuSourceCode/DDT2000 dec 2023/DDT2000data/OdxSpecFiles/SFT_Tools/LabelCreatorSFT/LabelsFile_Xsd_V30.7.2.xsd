									<xs:sequence>
										<xs:element name="DOC-REVISION" minOccurs="1" maxOccurs="1">
											<xs:complexType>
												<xs:sequence>
													<xs:element name="REVISIONS-SFT" minOccurs="1" maxOccurs="1">
														<xs:complexType>
														   <xs:sequence>
															  <xs:element name="REVISION-SFT" minOccurs="0" maxOccurs="unbounded"/>
														   </xs:sequence>
														</xs:complexType>
													</xs:element>
													<xs:element name="REVISION-LABEL" minOccurs="1" maxOccurs="1"/>
													<xs:element name="REVISION-LABEL-CREATOR" minOccurs="1" maxOccurs="1"/>
													<xs:element name="REVISION-LABEL-MERGER" minOccurs="1" maxOccurs="1"/>
