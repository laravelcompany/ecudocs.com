														<xs:attribute name="BitOffset" type="xs:string" use="optional"/>
														<xs:attribute name="Template" type="xs:string" use="optional"/>
													</xs:complexType>
												</xs:element>
											</xs:sequence>
											<xs:attribute name="Subname" type="xs:string" use="optional"/>
											<xs:attribute name="DDTLink" type="xs:string" use="optional"/>
											<xs:attribute name="DDTRQLink" type="xs:string" use="optional"/>
											<xs:attribute name="SN" type="xs:string" use="optional"/>
											<xs:attribute name="DefaultValue" type="xs:string" use="optional"/>
