                                <xs:sequence>
                                    <xs:element name="DataLink" minOccurs="1" maxOccurs="unbounded">
                                        <xs:complexType>
                                            <xs:sequence>
												<xs:element name="Category" minOccurs="0" maxOccurs="unbounded">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Line" minOccurs="0" maxOccurs="unbounded">
