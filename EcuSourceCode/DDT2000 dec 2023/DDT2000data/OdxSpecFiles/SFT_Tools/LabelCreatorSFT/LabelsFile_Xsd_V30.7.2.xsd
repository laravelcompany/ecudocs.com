                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="Label" type="LabelType7" minOccurs="0" maxOccurs="unbounded"/>
                                    </xs:sequence>
                                    <xs:attribute name="Text" type="xs:string"/>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="DataSaving" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="Label" type="LabelType8" minOccurs="0" maxOccurs="unbounded"/>
                                    </xs:sequence>
                                    <xs:attribute name="Text" type="xs:string"/>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
		<xs:attribute name="ecuID" type="xs:string" use="optional"/>
		<xs:attribute name="familyName" type="xs:string" use="optional"/>
		<xs:attribute name="protocolID" type="xs:string" use="optional"/>
        </xs:complexType>
    </xs:element>
    <xs:complexType name="RequirementType">
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute name="Name" type="xs:string" use="optional"/>
                <xs:attribute name="Constraints" type="xs:string" use="optional"/>
                <xs:attribute name="Conformity" type="xs:string" use="optional"/>
                <xs:attribute name="Comment" type="xs:string" use="optional"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
