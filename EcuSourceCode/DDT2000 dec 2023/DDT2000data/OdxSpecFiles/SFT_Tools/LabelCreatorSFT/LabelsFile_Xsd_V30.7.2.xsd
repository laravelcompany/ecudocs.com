        <xs:sequence>
            <xs:element name="Requirement" type="RequirementType"/>
            <xs:element name="Variants" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                    <xs:sequence>
						<xs:element name="VariantLink" minOccurs="0" maxOccurs="unbounded">
