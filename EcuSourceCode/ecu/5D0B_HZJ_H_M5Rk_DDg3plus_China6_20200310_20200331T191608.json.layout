     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 4920,
      "height": 270,
      "width": 8895
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "You have to consider the input value in 1 byte of HEX format for each case",
     "color": "rgb(64,0,128)",
     "alignment": "0",
     "fontcolor": "rgb(255,255,255)",
