      "width": 8175
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 10.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Step 2: Select item to control, it type and write the amount of value you want then push the button",
