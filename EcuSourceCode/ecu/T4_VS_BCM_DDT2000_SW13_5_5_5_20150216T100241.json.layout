     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "If the AFTER SALES MODE for BCM is launched, then put Ignition ON with a CID belonging to the vehicle",
     "color": "rgb(128,128,255)",
