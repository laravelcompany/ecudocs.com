      "height": 250,
      "width": 7000
     },
     "font": {
      "name": "Arial",
      "size": 8.0,
      "bold": "0",
      "italic": "0"
     },
     "fontcolor": "rgb(0,0,0)"
    },
    {
     "text": "VSC Status Bin APPrentissage bit 7: VSC LearningRunn_Cpy (learn)  bit 6: VSC Apprentissage r\u00e9ussit (learn)  bit 5: VSC Probl\u00e8me Renault (learn)  bit 4: VSC Probl\u00e8me UCH (learn)  bit 3: VSC Probl\u00e8me C\u00e2ble (learn)  bit 2: VSC Probl\u00e8me support badge (learn)  bit 1: VSC Probl\u00e8me badge (learn)  bit 0: VSC ApprentissageOK ou NOK (learn)",
     "request": "Read_A_AC_General_Identifiers_Learning_Status_(bits)_BCM_Input/Output",
     "color": "rgb(255,255,128)",
     "width": 4000,
     "rect": {
