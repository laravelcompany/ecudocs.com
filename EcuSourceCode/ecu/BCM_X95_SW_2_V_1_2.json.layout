   "color": "rgb(0,128,255)",
   "labels": [],
   "presend": [],
   "displays": [
    {
     "text": "VSC Status Bin Virginit\u00e9 bit 7: VSC Badge pr\u00e9sent ds support (virginit\u00e9)  bit 6: VSC IsVirginKey (virginit\u00e9) bit 5: VSC Probl\u00e8me de gamme Renault (virginit\u00e9) bit 4: VSC Probl\u00e8me support de badge (virginit\u00e9) bit 3: VSC Probl\u00e8me C\u00e2ble (virginit\u00e9) bit 2: VSC Probl\u00e8me UCH (virginit\u00e9) bit 1: VSC Probl\u00e8me badge (virginit\u00e9) bit 0: VSC TestDeVirginit\u00e9 (virginit\u00e9)",
     "request": "Read_A_AC_General_Identifiers_Learning_Status_(bits)_BCM_Input/Output",
     "color": "rgb(255,255,128)",
     "width": 4000,
     "rect": {
      "left": 1000,
      "top": 300,
      "height": 250,
      "width": 7000
     },
     "font": {
      "name": "Arial",
      "size": 8.0,
      "bold": "0",
      "italic": "0"
     },
     "fontcolor": "rgb(0,0,0)"
    },
    {
     "text": "VSC Status Bin Pr\u00e9sence bit 7: VSC Badge pr\u00e9sent ds support (pr\u00e9sent)  bit 6: VSC IsVirginKey (pr\u00e9sent) bit 5: VSC Probl\u00e8me de gamme Renault (pr\u00e9sent) bit 4: VSC Probl\u00e8me support de badge (pr\u00e9sent) bit 3: VSC Probl\u00e8me C\u00e2ble (pr\u00e9sent) bit 2: VSC Probl\u00e8me UCH (pr\u00e9sent) bit 1: VSC Probl\u00e8me badge (pr\u00e9sent) bit 0: VSC TestDePr\u00e9sence (pr\u00e9sent)",
     "request": "Read_A_AC_General_Identifiers_Learning_Status_(bits)_BCM_Input/Output",
     "color": "rgb(255,255,128)",
     "width": 4000,
     "rect": {
      "left": 1000,
