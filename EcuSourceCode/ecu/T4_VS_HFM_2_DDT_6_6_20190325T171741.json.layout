  "Aftersales Pairing : HFM or CID": {
   "width": 9660,
   "height": 11940,
   "color": "rgb(64,0,128)",
   "labels": [
    {
     "text": "AFTER SALES HFM or Customer IDs pairing  ",
     "color": "rgb(255,0,0)",
     "alignment": "2",
     "fontcolor": "rgb(64,0,64)",
     "bbox": {
      "left": 120,
      "top": 135,
      "height": 360,
      "width": 9360
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Pairing procedure : ",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 2760,
      "height": 4800,
      "width": 9360
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 8.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Complete the \"After Sales Code\" (16 bytes) and press the button \"ENTER AFTER SALES MODE\"",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 240,
      "top": 3000,
      "height": 360,
      "width": 9120
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "If the AFTER SALES MODE for HFM is launched, put a CID belonging to the vehicle in the reader then",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 240,
      "top": 4680,
      "height": 480,
      "width": 4320
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Parts Pairing information",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 5280,
      "top": 600,
      "height": 2040,
      "width": 3240
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
