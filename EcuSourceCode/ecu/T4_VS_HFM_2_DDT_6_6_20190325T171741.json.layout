      "size": 11.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Approach a Card belonging to the vehicle to the transponder antenna",
     "color": "rgb(255,255,170)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
