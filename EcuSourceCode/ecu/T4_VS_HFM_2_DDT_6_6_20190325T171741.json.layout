      "name": "Arial",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "6) Press the button \"EXIT GENESIS MODE\"",
     "color": "rgb(245,209,186)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 90,
      "top": 4695,
      "height": 600,
      "width": 8790
     },
     "font": {
      "name": "Arial",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "4) If the customer ID is paired, then insert a new customer ID in the reader and press \"CID pairing\"",
     "color": "rgb(245,209,186)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 75,
      "top": 3945,
      "height": 240,
      "width": 8805
     },
     "font": {
      "name": "Arial",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "5) Once all the customer IDs are paired, read the APV code and keep the value.",
     "color": "rgb(245,209,186)",
