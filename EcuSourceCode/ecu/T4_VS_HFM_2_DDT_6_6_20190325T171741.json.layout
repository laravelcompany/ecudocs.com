     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Press the button \"CID PAIRING\" for each CID to pair",
     "color": "rgb(128,128,255)",
     "alignment": "0",
