  "Reprog conditions(0)": {
   "width": 15540,
   "height": 11820,
   "color": "rgb(126,241,164)",
   "labels": [
    {
     "text": "if value=1 then the engine isn't running due to ECM",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 10200,
