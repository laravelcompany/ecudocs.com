      "name": "MS Sans Serif",
      "size": 8.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "if value=1 then the engine isn't running due to no BCM autorisation",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 10200,
