    },
    {
     "text": "ATTENTION: BIT 23 utilis\u00e9 uniquement en STEP 4",
     "color": "rgb(0,128,128)",
     "alignment": "2",
     "fontcolor": "rgb(255,255,255)",
     "bbox": {
      "left": 8400,
