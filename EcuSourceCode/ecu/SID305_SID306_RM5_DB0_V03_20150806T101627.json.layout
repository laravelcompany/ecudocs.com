      "width": 1455
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "BIT 0: Catalyst monitoring",
     "color": "rgb(143,143,143)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 8520,
      "top": 4080,
