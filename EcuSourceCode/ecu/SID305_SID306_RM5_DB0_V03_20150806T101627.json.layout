      "width": 6375
     },
     "font": {
      "name": "Arial",
      "size": 8.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "BIT 5: Oxygen sensor monitoring",
     "color": "rgb(143,143,143)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 8520,
      "top": 5280,
      "height": 240,
      "width": 3840
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Particle Filter Regeneration Need Diagnostic",
     "color": "rgb(128,128,192)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 9960,
      "top": 8880,
      "height": 1620,
      "width": 7273
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Diesel catalyst diagnostic.23 (specific SID305/6 RM5 DA0 or newer):",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 10080,
      "top": 9480,
      "height": 240,
      "width": 6840
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 6.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "- If the soot mass <16,4 g then value is 0 (no FAP imminent regeneration)",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 10410,
      "top": 9720,
      "height": 255,
      "width": 6510
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 6.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "- Else, if soot mass>=16,4 g, then the value is 1(the vehicle is in \"imminent regeneration\" mode, an APV regeneration and oil change must be done before the emission test",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 10410,
      "top": 9960,
      "height": 435,
      "width": 6510
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 6.0,
      "bold": "0",
      "italic": "0"
     }
    }
   ],
