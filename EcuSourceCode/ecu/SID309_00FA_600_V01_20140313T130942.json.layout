     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 360,
      "top": 1200,
      "height": 240,
      "width": 11040
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "  Les valeurs seront automatiquement initialis\u00e9es lors de l'appui du bouton, aucune saisie n'est n\u00e9cessaire.",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
