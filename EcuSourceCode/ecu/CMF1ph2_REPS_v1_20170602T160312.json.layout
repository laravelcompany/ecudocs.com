     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Supplier Fault Store can be erased only with CANap\u00e9 (not DDT2000)",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(15,15,15)",
     "bbox": {
      "left": 960,
      "top": 5040,
      "height": 720,
      "width": 6360
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Otherwise it means a major EPS fault occured (loss of assistance) => Please send a copy of this screen to EDL",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 8160,
      "top": 4200,
      "height": 840,
      "width": 3480
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
