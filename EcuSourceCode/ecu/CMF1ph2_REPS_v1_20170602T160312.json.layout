  "1 - SupplierInternalFaultStore": {
   "width": 11820,
   "height": 8820,
   "color": "rgb(255,255,128)",
   "labels": [
    {
     "text": "SupplierInternalFaultStore - Read",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 2760,
      "top": 240,
      "height": 480,
      "width": 5040
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 14.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "These codes are mainly related to CAN or voltage related faults",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 8040,
      "top": 3240,
