      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Values are coded in Hexa 1 fault (on 1 byte)",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": -360,
      "top": 1560,
