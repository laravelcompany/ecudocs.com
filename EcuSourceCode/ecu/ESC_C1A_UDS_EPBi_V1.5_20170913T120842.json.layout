  "41 - Hydraulic circuit test": {
   "width": 13980,
   "height": 11820,
   "color": "rgb(255,255,255)",
   "labels": [
    {
     "text": "Hydraulic circuit test routine",
     "color": "rgb(15,15,15)",
     "alignment": "2",
     "fontcolor": "rgb(255,255,255)",
     "bbox": {
      "left": -360,
      "top": 0,
      "height": 600,
      "width": 14415
     },
     "font": {
      "name": "Arial",
      "size": 16.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "WARNING : Do not perform the hydraulic circuit control if the hydraulic circuit is not well bled",
     "color": "rgb(255,128,128)",
     "alignment": "0",
     "fontcolor": "rgb(64,0,0)",
     "bbox": {
      "left": 0,
      "top": 585,
      "height": 2160,
      "width": 14160
     },
     "font": {
      "name": "Arial",
      "size": 16.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "To check if the hydraulic circuit is well bled:",
     "color": "rgb(255,128,128)",
     "alignment": "0",
     "fontcolor": "rgb(64,0,0)",
     "bbox": {
      "left": 150,
      "top": 1215,
      "height": 360,
      "width": 14205
     },
     "font": {
      "name": "Arial",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "If the pedal is hard, you can perform the hydraulic circuit control",
     "color": "rgb(255,128,128)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 1020,
      "top": 2280,
      "height": 300,
      "width": 12150
     },
     "font": {
      "name": "Arial",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "- Stop the engine and press 3 times the brake pedal:",
     "color": "rgb(255,128,128)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 360,
      "top": 1560,
      "height": 360,
      "width": 10920
     },
     "font": {
      "name": "Arial",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": " If the pedal is soft : air is present in the primary hydraulic circuit ==> perform the hydraulic bleeding procedure",
     "color": "rgb(255,128,128)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
