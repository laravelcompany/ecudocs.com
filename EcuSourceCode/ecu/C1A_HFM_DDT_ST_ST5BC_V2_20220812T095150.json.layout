     "text": "Pairing information",
     "color": "rgb(201,238,252)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 9120,
      "height": 1680,
      "width": 4560
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Genesis Mode Information",
     "color": "rgb(201,238,252)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 90,
      "top": 7320,
      "height": 1680,
      "width": 4560
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "3) Press the button \"CID pairing\" for each customer ID to pair",
     "color": "rgb(201,238,252)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 4440,
      "height": 1140,
      "width": 11280
     },
     "font": {
      "name": "Arial",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "6) Press the button \"EXIT GENESIS MODE\"",
     "color": "rgb(201,238,252)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 6360,
