  "Reset ECU (EEPROM clear/self-learning)": {
   "width": 11940,
   "height": 7380,
   "color": "rgb(255,255,128)",
   "labels": [
    {
     "text": "When ignition is switched ON, put gear lever in R position and slightly push accel pedal ",
     "color": "rgb(255,255,128)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 1800,
      "top": 840,
      "height": 360,
      "width": 7680
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Clear EEPROM and self lerning",
     "color": "rgb(128,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": -120,
      "top": 0,
      "height": 600,
      "width": 12240
     },
     "font": {
      "name": "@??",
      "size": 18.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Turn ignition OFF and wait at least 10 seconds",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 2040,
      "top": 1560,
      "height": 360,
      "width": 7200
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Switch ignition ON (lever always in Parking position) and wait until the flag displays \"completed\" ",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 240,
      "top": 5040,
      "height": 375,
      "width": 10560
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Automatic self-learning at ignition switched ON",
     "color": "rgb(255,128,64)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 0,
      "top": 4200,
      "height": 570,
      "width": 12120
     },
     "font": {
      "name": "@??",
      "size": 18.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Warning : it's not possible to check the writing of values in EEPROM",
     "color": "rgb(255,255,128)",
     "alignment": "0",
     "fontcolor": "rgb(255,0,0)",
     "bbox": {
      "left": 2160,
      "top": 6600,
      "height": 360,
      "width": 6975
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Switch ignition OFF again and wait at least 3 seconds, at next ignition ON the DK0-001 system is operational",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 0,
      "top": 6240,
      "height": 360,
      "width": 11160
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Turn ignition ON once again",
     "color": "rgb(255,255,128)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 4200,
      "top": 1920,
      "height": 300,
      "width": 3000
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Click Reset ECU/ Delete self-learning",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 2040,
      "top": 1200,
      "height": 360,
      "width": 7200
     },
     "font": {
      "name": "@??",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "The self-learning is automatically performed 3 seconds after ignition beginning",
     "color": "rgb(255,255,128)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 1680,
      "top": 2280,
