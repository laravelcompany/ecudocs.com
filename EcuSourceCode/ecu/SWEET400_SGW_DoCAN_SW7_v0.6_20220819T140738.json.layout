      "width": 5880
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "             Else, Choose \"Diag Com Mode START\" and ckick on WRITE button",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
