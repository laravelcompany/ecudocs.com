      "width": 6720
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Step 7: Go to Activation Tab to start ID Monitoring mode",
