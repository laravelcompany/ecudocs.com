    },
    {
     "text": "Step 1: Start Diag Session by clicking on START button",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 1200,
      "top": 1800,
      "height": 300,
      "width": 5760
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Step 2: Unlock the Gateway by clicking on the yellow padlock button",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 1200,
      "top": 2280,
      "height": 300,
      "width": 6240
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Step 3: If CGW status is \"Diag Com Mode\", then skip this step",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 1200,
      "top": 2760,
      "height": 300,
      "width": 5880
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "             Else, Choose \"Diag Com Mode START\" and ckick on WRITE button",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
