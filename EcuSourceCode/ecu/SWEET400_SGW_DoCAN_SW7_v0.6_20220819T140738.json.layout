      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Step 4: If CGW status is \"Diag Com Mode\", then skip this step",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
