    },
    {
     "text": "RX Network: Select the source bus from which the frame is coming",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 11400,
      "top": 2760,
      "height": 300,
      "width": 7200
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Step 3: Unlock the Gateway by clicking on the yellow padlock button",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 11040,
      "top": 3720,
      "height": 300,
      "width": 6240
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Step 4: If CGW status is \"Diag Com Mode\", then skip this step",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 11040,
      "top": 4200,
      "height": 300,
      "width": 5880
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "             Else, Choose \"Diag Com Mode START\" and ckick on WRITE button",
     "color": "rgb(223,223,223)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 10800,
      "top": 4560,
