     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Pairing procedure : ",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 600,
      "height": 3360,
      "width": 8040
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 8.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "3) Complete the \"After Sales Code\" (16 bytes) and press the button \"ENTER ESCL AFTER SALES MODE\"",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
