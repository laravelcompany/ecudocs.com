     }
    },
    {
     "text": "3) Press the button \"HFM pairing\" to pair the HFM",
     "color": "rgb(255,255,0)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
