      "top": 2400,
      "height": 360,
      "width": 7920
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 7.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Authentication information",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 4200,
      "top": 7200,
      "height": 2760,
      "width": 5280
     },
     "font": {
