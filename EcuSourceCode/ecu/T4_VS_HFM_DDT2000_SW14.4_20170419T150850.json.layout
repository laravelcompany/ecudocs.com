      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "1) Put Ignition ON and check that the ESCL is blank",
     "color": "rgb(128,128,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
