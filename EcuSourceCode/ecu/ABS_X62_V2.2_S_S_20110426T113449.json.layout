  "34 - Checking the magnetic encoder": {
   "width": 11340,
   "height": 9060,
   "color": "rgb(255,255,255)",
   "labels": [
    {
     "text": "CHECKING the Magnetic Encoder of each Wheel",
     "color": "rgb(255,255,255)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,255)",
     "bbox": {
      "left": 840,
      "top": 120,
      "height": 840,
      "width": 7200
     },
     "font": {
      "name": "Arial",
      "size": 16.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "1- Choice a Wheel",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 360,
      "top": 1080,
      "height": 240,
      "width": 2640
     },
     "font": {
      "name": "Arial",
      "size": 10.0,
