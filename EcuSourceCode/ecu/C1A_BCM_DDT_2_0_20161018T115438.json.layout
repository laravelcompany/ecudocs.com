  "Factory Genesis Pairing : BCM and CID": {
   "width": 11700,
   "height": 13020,
   "color": "rgb(0,64,128)",
   "labels": [
    {
     "text": "FACTORY GENESIS : BCM and Customer ID Pairing",
     "color": "rgb(221,238,255)",
     "alignment": "2",
     "fontcolor": "rgb(64,0,64)",
     "bbox": {
      "left": 90,
      "top": 120,
      "height": 360,
      "width": 11400
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Procedure",
     "color": "rgb(221,238,255)",
     "alignment": "2",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 2010,
      "height": 1605,
      "width": 11400
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 12.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "1) Check Ignition is OFF, then press \"ENTER GENESIS MODE\"",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 240,
      "top": 2520,
      "height": 480,
      "width": 11160
     },
     "font": {
      "name": "Arial",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "2) If the Genesis Mode is launched, then",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 4200,
      "height": 4440,
      "width": 11400
     },
     "font": {
      "name": "Arial",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "CID / BCM information",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 6720,
      "top": 8880,
      "height": 2160,
      "width": 4770
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "CID ANALYSE - Select \"StartRoutine\" and press the button",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(15,15,15)",
     "bbox": {
      "left": 120,
      "top": 570,
      "height": 1335,
      "width": 11400
     },
     "font": {
      "name": "@Arial Unicode MS",
      "size": 10.0,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Pairing information",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 10800,
      "height": 2160,
      "width": 6480
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Rework Mode failure ",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 8880,
      "height": 1815,
      "width": 6480
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "3) Press \"CID Pairing\"",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 5040,
      "height": 1440,
      "width": 11400
     },
     "font": {
      "name": "Arial",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "4) repeat step 2) and 3) for all CID to pair",
     "color": "rgb(221,238,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 120,
      "top": 6240,
      "height": 360,
      "width": 11400
     },
     "font": {
      "name": "Arial",
      "size": 9.0,
      "bold": "0",
      "italic": "0"
     }
    },
