  "31 - Pf-Lot definition - After Sale bleeding procedure": {
   "width": 12060,
   "height": 9060,
   "color": "rgb(255,255,255)",
   "labels": [
    {
     "text": "UBP B-sample Hydraulic circuit - Manual Bleeding procedure for Pf-Lot",
     "color": "rgb(0,0,0)",
     "alignment": "2",
