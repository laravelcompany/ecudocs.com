    },
    {
     "text": "L'ECM est \"autoprot\u00e9g\u00e9\" et n'autorise pas le d\u00e9marrage moteur.",
     "color": "rgb(198,198,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
