     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "-> L'ECM a subit une tentative \"d'intrusion\" ou a d\u00e9t\u00e9ct\u00e9 une erreur interne (EEPROM, FLASH...)",
     "color": "rgb(198,198,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 6330,
      "top": 10590,
      "height": 480,
      "width": 4680
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Bit5/Bit4 : 0=ECM virgin - Secret key not learnt / 1=Not used / 2=Not virgin ECM - Secret key learnt in erasable area / 3=Not virgin ECM - Secret key learnt in non erasable area",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 9600,
      "top": 3270,
      "height": 510,
      "width": 6480
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Bit0 : 0=Immobilizer engine running forbidden / 1=Immobilizer engine running authorized",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 9600,
      "top": 4440,
      "height": 240,
      "width": 6480
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "Bit6 : 0=ECM not protected / 1= ECM protected",
     "color": "rgb(255,255,255)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
     "bbox": {
      "left": 9600,
      "top": 2970,
      "height": 240,
      "width": 6480
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "0",
      "italic": "0"
     }
    },
    {
