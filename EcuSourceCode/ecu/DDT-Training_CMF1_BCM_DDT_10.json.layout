      "bold": "0",
      "italic": "0"
     }
    },
    {
     "text": "1) !! Check that you have access rights to the application \"Pairing using DDT2000\"",
     "color": "rgb(207,207,207)",
     "alignment": "0",
     "fontcolor": "rgb(0,0,0)",
