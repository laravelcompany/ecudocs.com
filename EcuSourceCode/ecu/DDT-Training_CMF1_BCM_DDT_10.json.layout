      "width": 5880
     },
     "font": {
      "name": "MS Sans Serif",
      "size": 8.25,
      "bold": "1",
      "italic": "0"
     }
    },
    {
     "text": "Pairing procedure exit is automatic. If the BCM is not SA unlocked , press ABORT",
     "color": "rgb(216,175,228)",
