---
// src/components/Brands.astro
export interface Props {
    limit?: number;
    className?: string;
}

// Import your brands data
import brandsData from "../data/brands.json";
import * as fs from "node:fs";
import * as path from "node:path";

const { limit, className = "" } = Astro.props;

function getBrandData(brandSlug: string) {
    const brandJsonPath = path.join(process.cwd(), "src", "data", brandSlug, "brand.json");
    if (fs.existsSync(brandJsonPath)) {
        try {
            return JSON.parse(fs.readFileSync(brandJsonPath, "utf-8"));
        } catch {
            return null;
        }
    }
    return null;
}

// Process the brands data
const allBrands = brandsData.map((row) => {
    const [id, uuid, url, name, imageUrl, desc, created_at, updated_at] = row;

    const slug = name
        .toLowerCase()
        .replace(/\s+/g, "-")
        .replace(/[^\w-]/g, "")
        .replace(/--+/g, "-")
        .replace(/^-|-$/g, "");

    const brandData = getBrandData(slug);

    return { 
        id, 
        name, 
        slug, 
        logo: `/images/brands/${slug}.jpg`,
        url,
        created_at, 
        updated_at,
        description: brandData?.description || "",
        productionModels: brandData?.productionModels || 0,
        discontinuedModels: brandData?.discontinuedModels || 0
    };
});

const brands = limit ? allBrands.slice(0, limit) : allBrands;
---

<div class={`columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4 ${className}`}>
    {brands.map((brand) => (
        <div class="break-inside-avoid mb-4">
            <a
                href={`/automobiles/brands/${brand.slug}`}
                class="block p-4 bg-white dark:bg-charcoal-800 border border-gray-200 dark:border-charcoal-700 rounded-lg shadow hover:shadow-md dark:hover:shadow-xl transition-shadow"
            >
                {brand.logo && (
                    <img
                        src={brand.logo}
                        alt={`${brand.name} logo ecu`}
                        class="w-12 h-12 object-contain mb-3"
                        loading="lazy"
                    />
                )}
                <h3 class="font-semibold text-gray-900 dark:text-white mb-1">{brand.name}</h3>
                {brand.description && (
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">{brand.description}</p>
                )}
                <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500 mb-3">
                    {brand.productionModels > 0 && (
                        <span><span class="font-semibold text-green-500">{brand.productionModels}</span> Production</span>
                    )}
                    {brand.discontinuedModels > 0 && (
                        <span><span class="font-semibold text-gray-500">{brand.discontinuedModels}</span> Discontinued</span>
                    )}
                </div>
                <span class="text-sm text-blue-600 dark:text-tomato-500">View ECU Docs</span>
            </a>
        </div>
    ))}
</div>