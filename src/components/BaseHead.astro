---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description,
  keywords = "Hardware ecu, documentation, database, e-bikes, e-scootes, car ecu, trucks ecu database, ecu database, ecu motorbikes",
  canonicalUrl = "https://ecudocs.com/",
  ogTitle,
  ogDescription,
} = Astro.props;

const siteUrl = "https://ecudocs.com/";
const fullTitle = title.includes("EcuDocs") ? title : `${title} | EcuDocs.com`;
const canonical = canonicalUrl.startsWith("http") ? canonicalUrl : `${siteUrl}${canonicalUrl.replace(/^\//, "")}`;
const ogTitleText = ogTitle || fullTitle;
const ogDescText = ogDescription || description;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content="EcuDocs.com" />

<!-- Favicons -->
<link rel="icon" href="https://i.imgur.com/GQePUq0.png" sizes="any" />
<link rel="icon" href="https://i.imgur.com/GQePUq0.png" type="image/svg+xml" />
<link rel="apple-touch-icon" href="https://i.imgur.com/GQePUq0.png" />
<link rel="manifest" href="/manifest.webmanifest" />

<!-- Favicon for IE -->
<link rel="shortcut icon" href="https://i.imgur.com/GQePUq0.png" type="image/x-icon" />

<!-- Favicons for different sizes -->
<link rel="icon" type="image/png" sizes="16x16" href="https://i.imgur.com/GQePUq0.png" />
<link rel="icon" type="image/png" sizes="32x32" href="https://i.imgur.com/GQePUq0.png" />
<link rel="icon" type="image/png" sizes="48x48" href="https://i.imgur.com/GQePUq0.png" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={ogTitleText} />
<meta property="og:description" content={ogDescText} />


<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="ahrefs-site-verification" content="86fe37da8ddae2c6dc5a5e70e5ac1107ccc6f740b4519d38e0e7537e2c4856ec" />
<meta name="googlebot" content="index, follow" />

<!-- Apple Touch Icon (already included in favicons, but keeping for backwards compatibility) -->
<link rel="apple-touch-icon" sizes="180x180" href="/logo.svg" />

<!-- Theme Color for Mobile Browsers -->
<meta name="theme-color" content="#3E433E" />

<!-- For IE -->
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

