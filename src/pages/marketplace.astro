---
import BaseLayout from "../layouts/BaseLayout.astro";
import Brands from "@/components/Brands.astro";
---

<BaseLayout
  title="Professional ECU Marketplace | Cloning, Tuning & Software Services"
  description="Professional ECU cloning, software calibration, and hardware diagnostics delivered by certified automotive engineers. ECU cloning from £75, remapping, immobilizer solutions."
  keywords="ECU cloning, ECU remapping, car tuning, immobilizer unlock, ECU programming, automotive diagnostics, performance tuning"
>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <!-- Marketplace Hero -->
    <header class="bg-charcoal-500 py-20 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(#fd6043_1px,transparent_1px)] [background-size:40px_40px]"></div>
      </div>
      
      <div class="container mx-auto px-4 relative z-10 text-center">
        <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter leading-none">
          Technical <span class="text-tomato-500 italic">Marketplace</span>
        </h1>
        <p class="text-xl text-charcoal-100 max-w-2xl mx-auto mb-10 font-medium">
          Professional ECU cloning, software calibration, and hardware diagnostics 
          delivered by certified automotive engineers.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
           <a href="#services" class="px-8 py-4 bg-tomato-500 hover:bg-tomato-600 rounded-2xl font-black text-lg transition-all shadow-xl shadow-tomato-500/20">Explore Services</a>
           <a href="/contact" class="px-8 py-4 bg-charcoal-700 hover:bg-charcoal-600 border border-charcoal-400 rounded-2xl font-bold text-lg transition-all backdrop-blur-sm">Custom Quote</a>
        </div>
      </div>
    </header>

    <!-- Services Grid -->
    <section id="services" class="py-24">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          
          <!-- Service Card 1 -->
          <div class="group bg-white dark:bg-charcoal-800 p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-charcoal-700 hover:shadow-2xl transition-all">
            <div class="mb-6 h-14 w-14 rounded-2xl bg-tomato-100 dark:bg-tomato-900/30 text-tomato-500 flex items-center justify-center">
               <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
            </div>
            <h3 class="text-2xl font-black mb-4 dark:text-white">ECU Cloning</h3>
            <p class="text-gray-500 dark:text-charcoal-300 mb-8 leading-relaxed">Full bit-for-bit cloning of your existing ECU hardware to a replacement unit. Plug-and-play guaranteed with all VIN and immobilizer data preserved.</p>
            <div class="flex items-center justify-between mt-auto">
               <span class="text-xs font-black text-tomato-500 uppercase tracking-widest">Starting from £75</span>
               <a href="/contact?service=cloning" class="text-sm font-bold underline hover:text-tomato-500 transition-colors">Book Now</a>
            </div>
          </div>

          <!-- Service Card 2 -->
          <div class="group bg-white dark:bg-charcoal-800 p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-charcoal-700 hover:shadow-2xl transition-all">
            <div class="mb-6 h-14 w-14 rounded-2xl bg-charcoal-100 dark:bg-charcoal-500 text-charcoal-500 dark:text-white flex items-center justify-center">
               <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
            </div>
            <h3 class="text-2xl font-black mb-4 dark:text-white">Software Re-mapping</h3>
            <p class="text-gray-500 dark:text-charcoal-300 mb-8 leading-relaxed">Stage 1 & 2 performance calibrations, EGR/DPF/AdBlue solutions, and fuel economy optimizations for all modern diesel and petrol units.</p>
            <div class="flex items-center justify-between mt-auto">
               <span class="text-xs font-black text-tomato-500 uppercase tracking-widest">Starting from £150</span>
               <a href="/contact?service=mapping" class="text-sm font-bold underline hover:text-tomato-500 transition-colors">Book Now</a>
            </div>
          </div>

          <!-- Service Card 3 -->
          <div class="group bg-white dark:bg-charcoal-800 p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-charcoal-700 hover:shadow-2xl transition-all">
            <div class="mb-6 h-14 w-14 rounded-2xl bg-negroni-100 dark:bg-negroni-900/30 text-negroni-700 flex items-center justify-center">
               <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-2xl font-black mb-4 dark:text-white">Immobilizer Unlock</h3>
            <p class="text-gray-500 dark:text-charcoal-300 mb-8 leading-relaxed">Immo-off services and virginizing for second-hand ECUs. Essential for custom engine swaps and track-day conversions.</p>
            <div class="flex items-center justify-between mt-auto">
               <span class="text-xs font-black text-tomato-500 uppercase tracking-widest">Starting from £60</span>
               <a href="/contact?service=immo" class="text-sm font-bold underline hover:text-tomato-500 transition-colors">Book Now</a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- How it Works -->
    <section class="py-24 bg-white dark:bg-charcoal-800 border-y border-gray-100 dark:border-charcoal-700">
       <div class="container mx-auto px-4 text-center mb-16">
          <h2 class="text-3xl font-black dark:text-white">Seamless Integration Process</h2>
       </div>
       <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
          <div class="text-center">
             <div class="text-5xl font-black text-tomato-500/20 mb-4">01</div>
             <h4 class="font-bold mb-2 dark:text-white">Request Service</h4>
             <p class="text-sm text-gray-500 dark:text-charcoal-300">Submit your vehicle data through our secure portal.</p>
          </div>
          <div class="text-center">
             <div class="text-5xl font-black text-tomato-500/20 mb-4">02</div>
             <h4 class="font-bold mb-2 dark:text-white">Ship Hardware</h4>
             <p class="text-sm text-gray-500 dark:text-charcoal-300">Courier your original and/or target ECU to our London lab.</p>
          </div>
          <div class="text-center">
             <div class="text-5xl font-black text-tomato-500/20 mb-4">03</div>
             <h4 class="font-bold mb-2 dark:text-white">Lab Processing</h4>
             <p class="text-sm text-gray-500 dark:text-charcoal-300">Engineering team performs validation and bit-writing.</p>
          </div>
          <div class="text-center">
             <div class="text-5xl font-black text-tomato-500/20 mb-4">04</div>
             <h4 class="font-bold mb-2 dark:text-white">Express Return</h4>
             <p class="text-sm text-gray-500 dark:text-charcoal-300">Units are tested and shipped back via next-day trackable mail.</p>
          </div>
       </div>
    </section>

    <!-- Brands Section -->
    <section class="py-24">
       <div class="container mx-auto px-4 text-center mb-16">
          <h3 class="text-2xl font-black dark:text-white opacity-50 uppercase tracking-[0.3em]">Supported Systems</h3>
       </div>
       <div class="container mx-auto px-4">
          <Brands limit={32} className="grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all cursor-pointer" />
       </div>
    </section>
  </main>
</BaseLayout>

