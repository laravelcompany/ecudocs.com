---
import BaseLayout from '../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';

const PINOUT_DIR = path.join(process.cwd(), 'src/content/pinout');

function getPinoutFolders() {
  const folders = [];
  
  if (!fs.existsSync(PINOUT_DIR)) {
    return folders;
  }
  
  const manufacturers = fs.readdirSync(PINOUT_DIR);
  
  for (const manufacturer of manufacturers) {
    const manufacturerPath = path.join(PINOUT_DIR, manufacturer);
    const stat = fs.statSync(manufacturerPath);
    
    if (!stat.isDirectory()) continue;
    
    const models = fs.readdirSync(manufacturerPath);
    
    for (const model of models) {
      const modelPath = path.join(manufacturerPath, model);
      const modelStat = fs.statSync(modelPath);
      
      if (!modelStat.isDirectory()) continue;
      
      const files = fs.readdirSync(modelPath).filter(f => !fs.statSync(path.join(modelPath, f)).isDirectory());
      const images = files.filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f));
      
      const firstImage = images.length > 0 ? `/content/pinout/${manufacturer}/${model}/${images[0]}` : null;
      
      const baseModel = model.replace(/\s*\([^)]*\)/, '').trim();
      
      folders.push({
        manufacturer,
        model,
        baseModel,
        slug: model.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
        image: firstImage,
        imageCount: images.length
      });
    }
  }
  
  return folders;
}

const pinouts = getPinoutFolders();

const groupedPinouts = pinouts.reduce((acc, pinout) => {
  const key = `${pinout.manufacturer}-${pinout.baseModel}`;
  if (!acc[key]) {
    acc[key] = {
      manufacturer: pinout.manufacturer,
      baseModel: pinout.baseModel,
      variants: []
    };
  }
  acc[key].variants.push({
    model: pinout.model,
    slug: pinout.slug,
    image: pinout.image,
    imageCount: pinout.imageCount
  });
  return acc;
}, {});

const groupedList = Object.values(groupedPinouts).sort((a, b) => 
  a.baseModel.localeCompare(b.baseModel)
);
---

<BaseLayout
  title="ECU Pinout Database | EcuDocs.com"
  description="Browse our collection of ECU pinout diagrams and pin configurations for various manufacturers including Bosch, Delphi, and more."
  keywords="ECU pinout, pinout diagram, ECU connector, wiring diagram, Bosch pinout, ECU terminal"
>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <header class="bg-charcoal-500 py-16 text-white text-center">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-extrabold tracking-tight mb-4">
          ECU <span class="text-tomato-500">Pinout</span> Database
        </h1>
        <p class="text-charcoal-100 max-w-2xl mx-auto">
          Explore our collection of ECU pinout diagrams and terminal configurations.
        </p>
      </div>
    </header>

    <div class="container mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {groupedList.map(group => (
          <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700 overflow-hidden">
            <div class="p-6">
              <h3 class="text-xl font-black text-gray-900 dark:text-white mb-4">
                {group.manufacturer} {group.baseModel}
              </h3>
              <div class="space-y-2">
                {group.variants.map(variant => (
                  <a 
                    href={`/pinout/${variant.slug}`}
                    class="flex items-center justify-between p-3 rounded-xl bg-gray-50 dark:bg-charcoal-700/50 hover:bg-tomato-50 dark:hover:bg-tomato-900/20 transition-colors group/item"
                  >
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-200 group-hover/item:text-tomato-600 dark:group-hover/item:text-tomato-400">
                      {variant.model}
                    </span>
                    <div class="flex items-center gap-2">
                      {variant.imageCount > 0 && (
                        <span class="text-xs text-charcoal-400">
                          {variant.imageCount} img{variant.imageCount !== 1 ? 's' : ''}
                        </span>
                      )}
                      <svg class="h-4 w-4 text-charcoal-400 group-hover/item:text-tomato-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>