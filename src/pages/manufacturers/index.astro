---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ecuManufacturers from '../../content/ecu-manufactures.json';

const { ecu_manufacturers } = ecuManufacturers;

const tier1 = ecu_manufacturers.filter(m => m.market_tier === 1);
const tier2 = ecu_manufacturers.filter(m => m.market_tier === 2);
const tier3 = ecu_manufacturers.filter(m => m.market_tier === 3);

const countries = [...new Set(ecu_manufacturers.map(m => m.country).filter(Boolean))].sort();
---

<BaseLayout
  title="ECU Manufacturers | EcuDocs.com"
  description="Browse ECU manufacturers and suppliers from around the world. Learn about top automotive electronics companies."
  keywords="ECU manufacturers, automotive suppliers, ECU companies, electronics suppliers, Bosch, Continental, Denso"
>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <header class="bg-charcoal-500 py-16 text-white text-center">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-extrabold tracking-tight mb-4 tracking-tight">
          ECU <span class="text-tomato-500">Manufacturers</span>
        </h1>
        <p class="text-charcoal-100 max-w-2xl mx-auto">
          Explore {ecu_manufacturers.length} automotive ECU manufacturers and suppliers from around the world.
        </p>
      </div>
    </header>

    <div class="container mx-auto px-4 py-12">
      <div class="flex flex-wrap gap-4 mb-12 justify-center">
        <button
          data-country="all"
          class="filter-btn px-4 py-2 bg-tomato-500 text-white rounded-full text-sm font-bold shadow-sm border border-tomato-500"
        >
          All
        </button>
        {countries.map(country => (
          <button
            data-country={country}
            class="filter-btn px-4 py-2 bg-white dark:bg-charcoal-800 rounded-full text-sm font-bold text-gray-600 dark:text-charcoal-300 shadow-sm border border-gray-200 dark:border-charcoal-700 hover:border-tomato-500 hover:text-tomato-500 transition-colors"
          >
            {country}
          </button>
        ))}
      </div>

      <div class="mb-12">
        <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
          <span class="w-3 h-3 bg-tomato-500 rounded-full"></span>
          Tier 1 - Global Suppliers ({tier1.length})
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {tier1.map(manufacturer => (
            <div class="manufacturer-card bg-white dark:bg-charcoal-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700" data-country={manufacturer.country}>
              <div class="flex items-start justify-between mb-3">
                <h3 class="text-lg font-black text-gray-900 dark:text-white">{manufacturer.name}</h3>
                <span class="px-2 py-1 bg-tomato-500/10 text-tomato-500 text-xs font-black uppercase rounded">Tier 1</span>
              </div>
              <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-charcoal-300 mb-3">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  {manufacturer.country}
                </span>
                {manufacturer.founded && (
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    Est. {manufacturer.founded}
                  </span>
                )}
              </div>
              <p class="text-gray-600 dark:text-charcoal-300 text-sm leading-relaxed">{manufacturer.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-12">
        <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
          <span class="w-3 h-3 bg-blue-500 rounded-full"></span>
          Tier 2 - Regional Suppliers ({tier2.length})
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {tier2.map(manufacturer => (
            <div class="manufacturer-card bg-white dark:bg-charcoal-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700" data-country={manufacturer.country}>
              <div class="flex items-start justify-between mb-3">
                <h3 class="text-lg font-black text-gray-900 dark:text-white">{manufacturer.name}</h3>
                <span class="px-2 py-1 bg-blue-500/10 text-blue-500 text-xs font-black uppercase rounded">Tier 2</span>
              </div>
              <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-charcoal-300 mb-3">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  {manufacturer.country}
                </span>
                {manufacturer.founded && (
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    Est. {manufacturer.founded}
                  </span>
                )}
              </div>
              <p class="text-gray-600 dark:text-charcoal-300 text-sm leading-relaxed">{manufacturer.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
          <span class="w-3 h-3 bg-green-500 rounded-full"></span>
          Tier 3 - Niche & Specialty ({tier3.length})
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {tier3.map(manufacturer => (
            <div class="manufacturer-card bg-white dark:bg-charcoal-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700" data-country={manufacturer.country || 'unknown'}>
              <div class="flex items-start justify-between mb-3">
                <h3 class="text-lg font-black text-gray-900 dark:text-white">{manufacturer.name}</h3>
                <span class="px-2 py-1 bg-green-500/10 text-green-500 text-xs font-black uppercase rounded">Tier 3</span>
              </div>
              <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-charcoal-300 mb-3">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  {manufacturer.country || 'Unknown'}
                </span>
                {manufacturer.founded && (
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    Est. {manufacturer.founded}
                  </span>
                )}
              </div>
              <p class="text-gray-600 dark:text-charcoal-300 text-sm leading-relaxed">{manufacturer.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </main>

  <script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const country = btn.dataset.country;
        
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('bg-tomato-500', 'text-white', 'border-tomato-500');
          b.classList.add('bg-white', 'dark:bg-charcoal-800', 'text-gray-600', 'dark:text-charcoal-300', 'border-gray-200', 'dark:border-charcoal-700');
        });
        
        btn.classList.remove('bg-white', 'dark:bg-charcoal-800', 'text-gray-600', 'dark:text-charcoal-300', 'border-gray-200', 'dark:border-charcoal-700');
        btn.classList.add('bg-tomato-500', 'text-white', 'border-tomato-500');

        document.querySelectorAll('.manufacturer-card').forEach(card => {
          const cardCountry = card.dataset.country;
          if (country === 'all' || cardCountry === country) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>