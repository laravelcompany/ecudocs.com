---
import BaseLayout from '../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';

const ECUS_DIR = path.join(process.cwd(), 'public', 'ecus');

export function getStaticPaths() {
  const ECUS_DIR = path.join(process.cwd(), 'public', 'ecus');
  const files = fs.readdirSync(ECUS_DIR);
  
  return files
    .filter(f => f.endsWith('.json'))
    .map((file) => {
      return {
        params: { slug: file.replace('.json', '') },
        props: { file },
      };
    });
}
const { file } = Astro.props;
const filePath = path.join(ECUS_DIR, file);
const content = fs.readFileSync(filePath, 'utf-8');
const data = JSON.parse(content);
const slug = file.replace('.json', '');
---

<BaseLayout
  title={`${data.ecuname || slug} Technical Specifications | EcuDocs.com`}
  description={`View detailed technical specifications for ${data.ecuname || slug}. Includes OBD configuration, protocols, and hardware parameters.`}
  keywords={`${data.ecuname || slug}, ECU specs, OBD protocol, ${data.obd?.protocol || ''}, hardware configuration`}
>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <!-- ECU Detail Hero -->
    <header class="bg-charcoal-500 py-12 text-white overflow-hidden relative">
       <div class="absolute right-0 top-0 h-32 w-32 bg-tomato-500/20 blur-3xl rounded-full translate-x-12 -translate-y-12"></div>
       
       <div class="container mx-auto px-4 relative z-10">
        <nav class="mb-6 flex text-xs font-bold uppercase tracking-widest text-charcoal-300" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-2">
            <li><a href="/ecu" class="hover:text-white transition-colors">Database</a></li>
            <li><span class="px-2">/</span></li>
            <li class="text-white" aria-current="page">{data.ecuname || slug}</li>
          </ol>
        </nav>

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <span class="inline-block px-3 py-1 rounded-full bg-tomato-500/20 text-tomato-400 text-[10px] font-black uppercase tracking-widest mb-4 border border-tomato-500/30">
              Hardware Component File
            </span>
            <h1 class="text-4xl md:text-5xl font-black tracking-tight">{data.ecuname || slug}</h1>
            <p class="text-charcoal-100 mt-2 font-medium opacity-80">System Identification and Configuration Data</p>
          </div>
          
          <div class="flex gap-4">
            <button onclick="window.print()" class="px-6 py-3 rounded-xl bg-charcoal-700/50 border border-charcoal-400 text-sm font-bold backdrop-blur-sm hover:bg-charcoal-600 transition-all flex items-center gap-2">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
              PDF Export
            </button>
          </div>
        </div>
      </div>
    </header>

    <div class="container mx-auto px-4 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        
        <!-- Technical Sidebar -->
        <aside class="lg:col-span-1 space-y-8">
           <div class="bg-white dark:bg-charcoal-800 p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700">
             <h3 class="text-xs font-black uppercase tracking-widest text-charcoal-400 mb-6">Metadata</h3>
             <div class="space-y-6">
                <div>
                   <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-tighter">File reference</span>
                   <code class="text-xs font-mono text-tomato-500 break-all">{file}</code>
                </div>
                <div>
                   <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-tighter">Source type</span>
                   <span class="text-sm font-bold text-gray-900 dark:text-white uppercase">JSON Data Array</span>
                </div>
                <div>
                   <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-tighter">Status</span>
                   <div class="flex items-center gap-2 mt-1">
                      <span class="h-2 w-2 rounded-full bg-green-500"></span>
                      <span class="text-sm font-bold text-gray-900 dark:text-white">Validated</span>
                   </div>
                </div>
             </div>
           </div>

           <div class="bg-charcoal-900 p-8 rounded-3xl text-white shadow-2xl relative overflow-hidden group">
             <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:rotate-12 transition-transform duration-500">
                <svg class="h-24 w-24" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
             </div>
             <h4 class="text-lg font-black italic mb-2">Technical Warning</h4>
             <p class="text-xs text-charcoal-200 leading-relaxed mb-4">Ensure specific OBD protocol matching before hardware implementation to avoid controller lockout.</p>
             <a href="/contact" class="text-[10px] font-black uppercase tracking-widest text-tomato-400 hover:text-tomato-300 transition-colors">Safety Guidelines →</a>
           </div>
        </aside>

        <!-- Main Spec Content -->
        <div class="lg:col-span-3 space-y-12">
          
          {data.obd && (
            <section>
              <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
                <span class="h-8 w-1 bg-tomato-500 rounded-full"></span>
                OBD Configuration Details
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {[
                  { label: "Protocol", value: data.obd.protocol },
                  { label: "Baudrate", value: data.obd.baudrate },
                  { label: "Send ID", value: data.obd.send_id },
                  { label: "Receive ID", value: data.obd.recv_id },
                  { label: "Functional Addr", value: data.obd.funcaddr },
                  { label: "Functional Name", value: data.obd.funcname },
                ].map(info => (
                  <div class="bg-white dark:bg-charcoal-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700 transition-all hover:border-tomato-500/30">
                    <span class="block text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">{info.label}</span>
                    <span class="text-lg font-mono font-bold text-gray-900 dark:text-white">{info.value || 'N/A'}</span>
                  </div>
                ))}
              </div>
            </section>
          )}

          {data.autoidents && data.autoidents.length > 0 && (
            <section>
              <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
                <span class="h-8 w-1 bg-charcoal-500 rounded-full"></span>
                Automatic Identifiers
              </h2>
              <div class="rounded-2xl overflow-hidden bg-white dark:bg-charcoal-800 shadow-sm border border-gray-100 dark:border-charcoal-700">
                 <div class="bg-gray-50 dark:bg-charcoal-700/50 px-6 py-2 border-b border-gray-100 dark:border-charcoal-700 flex justify-between items-center">
                    <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Array Listing</span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-tomato-500">{data.autoidents.length} Entries</span>
                 </div>
                 <div class="p-6">
                    <pre class="font-mono text-sm leading-relaxed overflow-x-auto text-gray-800 dark:text-charcoal-100 whitespace-pre-wrap">{JSON.stringify(data.autoidents, null, 2)}</pre>
                 </div>
              </div>
            </section>
          )}

          {data.devices && data.devices.length > 0 && (
            <section>
              <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
                <span class="h-8 w-1 bg-charcoal-500 rounded-full"></span>
                Associated Devices
              </h2>
              <div class="grid grid-cols-1 gap-4">
                 {data.devices.map((device) => (
                    <div class="group bg-white dark:bg-charcoal-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700 flex justify-between items-center transition-all hover:bg-gray-50 dark:hover:bg-charcoal-700/30">
                       <span class="text-base font-bold text-gray-900 dark:text-white">{device.name || 'Unnamed Device'}</span>
                       <span class="text-xs font-mono text-charcoal-400 group-hover:text-tomato-500 uppercase tracking-tighter">ID: {device.id}</span>
                    </div>
                 ))}
              </div>
            </section>
          )}

          {data.requests && data.requests.length > 0 && (
            <section>
              <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3">
                <span class="h-8 w-1 bg-tomato-500 rounded-full"></span>
                Technical Requests (IO)
              </h2>
              <div class="grid grid-cols-1 gap-4">
                 {data.requests.map((req) => (
                    <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700 overflow-hidden">
                       <div class="bg-gray-50 dark:bg-charcoal-700/50 px-6 py-4 border-b border-gray-100 dark:border-charcoal-700 flex justify-between items-center">
                          <span class="text-base font-bold text-gray-900 dark:text-white">{req.name || 'Unnamed Request'}</span>
                          <span class="text-[10px] font-black uppercase tracking-widest text-tomato-500">I/O Sequence</span>
                       </div>
                       <div class="p-6">
                          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                             <div>
                                <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-tighter mb-2">Sent Bytes</span>
                                <code class="text-sm font-mono text-charcoal-500 dark:text-charcoal-200 break-all bg-gray-100 dark:bg-charcoal-900 px-3 py-2 rounded-xl block border border-gray-200 dark:border-charcoal-600">{req.sentbytes || 'N/A'}</code>
                             </div>
                             <div>
                                <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-tighter mb-2">Reply Bytes</span>
                                <code class="text-sm font-mono text-tomato-500 break-all bg-tomato-50 dark:bg-tomato-900/20 px-3 py-2 rounded-xl block border border-tomato-100 dark:border-tomato-500/30">{req.replybytes || 'N/A'}</code>
                             </div>
                          </div>
                          
                          {req.receivebyte_dataitems && Object.keys(req.receivebyte_dataitems).length > 0 && (
                             <div class="mt-6 pt-4 border-t border-gray-100 dark:border-charcoal-700">
                               <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-tighter mb-3">Data Items</span>
                               <div class="flex flex-wrap gap-2">
                                 {Object.keys(req.receivebyte_dataitems).map(key => (
                                    <span class="text-xs px-2.5 py-1 rounded bg-gray-100 dark:bg-charcoal-700 text-gray-600 dark:text-gray-300 font-medium">{key}</span>
                                 ))}
                               </div>
                             </div>
                          )}
                       </div>
                    </div>
                 ))}
              </div>
            </section>
          )}

        </div>
      </div>
    </div>
  </main>
</BaseLayout>

