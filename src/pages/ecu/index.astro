---
import BaseLayout from '../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';

const ECUS_DIR = path.join(process.cwd(), 'public', 'ecus');

const PAGE_SIZE = 50;
const files = fs.readdirSync(ECUS_DIR);
const allEcus = files.filter(f => f.endsWith('.json'));
const totalPages = Math.ceil(allEcus.length / PAGE_SIZE);

const currentPage = Number(Astro.url.searchParams.get('page') || 1);
const searchQuery = Astro.url.searchParams.get('q') || '';

const start = (currentPage - 1) * PAGE_SIZE;
const pageFiles = allEcus.slice(start, start + PAGE_SIZE);

const ecus = pageFiles.map(file => {
  const content = fs.readFileSync(path.join(ECUS_DIR, file), 'utf-8');
  return { file, slug: file.replace('.json', ''), data: JSON.parse(content) };
});

const allEcusMeta = allEcus.map(file => {
  const content = fs.readFileSync(path.join(ECUS_DIR, file), 'utf-8');
  const data = JSON.parse(content);
  return { 
    file, 
    slug: file.replace('.json', ''),
    ecuname: data.ecuname || file.replace('.json', ''),
    protocol: data.obd?.protocol || '',
    baudrate: data.obd?.baudrate || ''
  };
});
---

<BaseLayout title={`ECU Database | Hardware Engine Control Unit Hub`}>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <!-- ECU Hero Header -->
    <header class="bg-charcoal-500 py-16 text-white text-center">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-extrabold tracking-tight mb-4 tracking-tight">
          ECU <span class="text-tomato-500">Database</span> Hub
        </h1>
        <p class="text-charcoal-100 max-w-2xl mx-auto">
          Explore our massive collection of {allEcus.length} hardware ECU configuration files. 
          Search by name, OBD protocol, or baudrate.
        </p>
      </div>
    </header>

    <div class="container mx-auto px-4 -mt-8 relative z-10">
      <!-- Search Section -->
      <div class="max-w-3xl mx-auto">
        <div class="relative group">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Search ECUs by name, protocol, or baudrate..." 
            value={searchQuery}
            class="w-full pl-14 pr-6 py-5 bg-white dark:bg-charcoal-800 rounded-3xl shadow-2xl border-none text-lg dark:text-white focus:ring-4 focus:ring-tomato-500/20 transition-all outline-none"
          />
          <div class="absolute left-5 top-1/2 -translate-y-1/2 text-charcoal-300 group-focus-within:text-tomato-500 transition-colors">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
        </div>
        <div id="resultsInfo" class="mt-4 text-center text-sm font-bold text-gray-500 dark:text-charcoal-300 uppercase tracking-widest"></div>
      </div>
    </div>

    <!-- ECU Grid -->
    <div class="container mx-auto px-4 py-12">
      <div id="ecuGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {ecus.map(({ slug, file, data }) => (
          <a 
            href={`/ecu/${slug}`} 
            class="group bg-white dark:bg-charcoal-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700 hover:shadow-xl hover:-translate-y-1 transition-all"
            data-search={(`${data.ecuname || file.replace('.json', '')} ${data.obd?.protocol || ''} ${data.obd?.baudrate || ''}`).toLowerCase()}
          >
            <div class="mb-4">
              <span class="text-[10px] font-black uppercase tracking-widest text-tomato-500 mb-1 block">Hardware Config</span>
              <h3 class="text-lg font-black text-gray-900 dark:text-white group-hover:text-tomato-500 transition-colors">
                {data.ecuname || file.replace('.json', '')}
              </h3>
            </div>
            
            {data.obd && (
              <div class="space-y-2 pt-4 border-t border-gray-50 dark:border-charcoal-700">
                <div class="flex items-center text-xs text-gray-500 dark:text-charcoal-300">
                  <span class="w-20 font-bold uppercase tracking-tighter opacity-50">Protocol</span>
                  <span class="font-mono text-gray-900 dark:text-white">{data.obd.protocol}</span>
                </div>
                <div class="flex items-center text-xs text-gray-500 dark:text-charcoal-300">
                  <span class="w-20 font-bold uppercase tracking-tighter opacity-50">Baudrate</span>
                  <span class="font-mono text-gray-900 dark:text-white">{data.obd.baudrate}</span>
                </div>
              </div>
            )}
            
            <div class="mt-6 flex justify-end">
               <div class="text-xs font-black uppercase tracking-widest text-charcoal-400 group-hover:text-tomato-500 transition-colors flex items-center gap-1">
                 View Data <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
               </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Pagination -->
      <div id="pagination" class="mt-16 flex justify-center items-center gap-4">
        {currentPage > 1 && (
          <a href={`/ecu?page=${currentPage - 1}${searchQuery ? `&q=${searchQuery}` : ''}`} class="px-6 py-3 rounded-xl bg-white dark:bg-charcoal-800 font-bold text-sm shadow-sm border border-gray-200 dark:border-charcoal-700 hover:bg-gray-50 transition-colors">← Earlier</a>
        )}
        <span class="text-xs font-black uppercase tracking-widest text-gray-400">Page {currentPage} of {totalPages}</span>
        {currentPage < totalPages && (
          <a href={`/ecu?page=${currentPage + 1}${searchQuery ? `&q=${searchQuery}` : ''}`} class="px-6 py-3 rounded-xl bg-white dark:bg-charcoal-800 font-bold text-sm shadow-sm border border-gray-200 dark:border-charcoal-700 hover:bg-gray-50 transition-colors">Later →</a>
        )}
      </div>
    </div>
  </main>

  <script define:vars={{ allEcusMeta, PAGE_SIZE }}>
    const searchInput = document.getElementById('searchInput');
    const ecuGrid = document.getElementById('ecuGrid');
    const resultsInfo = document.getElementById('resultsInfo');
    const pagination = document.getElementById('pagination');
    
    let filteredEcus = [...allEcusMeta];

    function renderECUs(ecus, page = 1) {
      const start = (page - 1) * PAGE_SIZE;
      const pageEcus = ecus.slice(start, start + PAGE_SIZE);
      const totalPages = Math.ceil(ecus.length / PAGE_SIZE);

      if (pageEcus.length === 0) {
        ecuGrid.innerHTML = `
          <div class="col-span-full py-20 text-center">
            <div class="text-gray-300 mb-4 flex justify-center">
              <svg class="h-20 w-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-600 dark:text-charcoal-300">Zero matches for your query</h3>
            <p class="text-gray-400">Try searching for a specific protocol or partial name.</p>
          </div>
        `;
        pagination.innerHTML = '';
        return;
      }

      ecuGrid.innerHTML = pageEcus.map(ecu => `
        <a href="/ecu/${ecu.slug}" class="group bg-white dark:bg-charcoal-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-charcoal-700 hover:shadow-xl hover:-translate-y-1 transition-all">
          <div class="mb-4">
            <span class="text-[10px] font-black uppercase tracking-widest text-tomato-500 mb-1 block">Hardware Config</span>
            <h3 class="text-lg font-black text-gray-900 dark:text-white group-hover:text-tomato-500 transition-colors">${ecu.ecuname}</h3>
          </div>
          <div class="space-y-2 pt-4 border-t border-gray-50 dark:border-charcoal-700">
            <div class="flex items-center text-xs text-gray-500 dark:text-charcoal-300">
              <span class="w-20 font-bold uppercase tracking-tighter opacity-50">Protocol</span>
              <span class="font-mono text-gray-900 dark:text-white">${ecu.protocol || '---'}</span>
            </div>
            <div class="flex items-center text-xs text-gray-500 dark:text-charcoal-300">
              <span class="w-20 font-bold uppercase tracking-tighter opacity-50">Baudrate</span>
              <span class="font-mono text-gray-900 dark:text-white">${ecu.baudrate || '---'}</span>
            </div>
          </div>
          <div class="mt-6 flex justify-end">
             <div class="text-xs font-black uppercase tracking-widest text-charcoal-400 group-hover:text-tomato-500 transition-colors flex items-center gap-1">
               View Data <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
             </div>
          </div>
        </a>
      `).join('');

      let paginationHtml = '';
      if (totalPages > 1) {
        if (page > 1) {
          paginationHtml += `<button onclick="window.renderSearchPage(${page - 1})" class="px-6 py-3 rounded-xl bg-white dark:bg-charcoal-800 font-bold text-sm shadow-sm border border-gray-200 dark:border-charcoal-700 hover:bg-gray-50 transition-colors">← Earlier</button>`;
        }
        paginationHtml += `<span class="text-xs font-black uppercase tracking-widest text-gray-400">Page ${page} of ${totalPages}</span>`;
        if (page < totalPages) {
          paginationHtml += `<button onclick="window.renderSearchPage(${page + 1})" class="px-6 py-3 rounded-xl bg-white dark:bg-charcoal-800 font-bold text-sm shadow-sm border border-gray-200 dark:border-charcoal-700 hover:bg-gray-50 transition-colors">Later →</button>`;
        }
      }
      pagination.innerHTML = paginationHtml;
    }

    window.renderSearchPage = (page) => {
      renderECUs(filteredEcus, page);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function performSearch(query) {
      const q = query.toLowerCase();
      filteredEcus = allEcusMeta.filter(ecu => 
        ecu.ecuname.toLowerCase().includes(q) ||
        ecu.protocol.toLowerCase().includes(q) ||
        ecu.baudrate.toLowerCase().includes(q)
      );
      
      const newUrl = query ? `?q=${encodeURIComponent(query)}` : '/ecu';
      window.history.replaceState({}, '', newUrl);
      
      renderECUs(filteredEcus, 1);
      
      resultsInfo.textContent = query ? `${filteredEcus.length} MATCHES FOUND` : '';
    }

    let debounceTimer;
    searchInput.addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        performSearch(e.target.value);
      }, 300);
    });

    if (searchInput.value) {
      performSearch(searchInput.value);
    }
  </script>
</BaseLayout>
