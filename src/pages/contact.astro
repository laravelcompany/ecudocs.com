---
import BaseLayout from "../layouts/BaseLayout.astro";
import Brands from "@/components/Brands.astro";
---

<BaseLayout
  title="Contact Us | EcuDocs.com"
  description="Get in touch with EcuDocs.com for ECU documentation requests, technical support, or marketplace services. Our engineering team is ready to help."
  keywords="contact ECU docs, technical support, ECU help, automotive diagnostics support"
>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <header class="bg-charcoal-500 py-20 text-white text-center">
      <div class="container mx-auto px-4">
        <h1 class="text-5xl font-black mb-6">Contact Us</h1>
        <p class="text-xl text-charcoal-100 max-w-2xl mx-auto">
          Get in touch with our engineering team for technical support, documentation requests, or marketplace services.
        </p>
      </div>
    </header>
    
    <div class="container mx-auto px-4 py-16 max-w-2xl">
      <div class="bg-white dark:bg-charcoal-800 rounded-3xl p-8 shadow-xl">
        <form class="space-y-6">
          <div>
            <label class="block text-sm font-bold text-gray-700 dark:text-white mb-2">Name</label>
            <input type="text" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-charcoal-600 bg-white dark:bg-charcoal-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-tomato-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-bold text-gray-700 dark:text-white mb-2">Email</label>
            <input type="email" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-charcoal-600 bg-white dark:bg-charcoal-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-tomato-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-bold text-gray-700 dark:text-white mb-2">Message</label>
            <textarea rows="5" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-charcoal-600 bg-white dark:bg-charcoal-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-tomato-500 outline-none resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-tomato-500 hover:bg-tomato-600 text-white font-black py-4 rounded-xl transition-colors shadow-lg">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </main>
</BaseLayout>

