---
import Layout from '../../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';
import brandsData from '../../../data/brands.json';

export function getStaticPaths() {
  return brandsData.map((brand) => {
    const [id, uuid, url, name, imageUrl, desc, createdAt, updatedAt] = brand;
    const slug = name
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w-]/g, '')
      .replace(/--+/g, '-')
      .replace(/^-|-$/g, '');
    
    return {
      params: { brand: slug },
      props: { 
        brandName: name,
        brandUrl: url,
        brandLogo: `/images/brands/${slug}.jpg`,
        brandSlug: slug
      }
    };
  });
}

const { brand } = Astro.params;
const { brandName, brandUrl, brandLogo, brandSlug } = Astro.props;

// Load models for this brand from src/data/[brandSlug]/models.json
let models = [];
const modelsPath = path.join(process.cwd(), 'src', 'data', brandSlug, 'models.json');
if (fs.existsSync(modelsPath)) {
  try {
    models = JSON.parse(fs.readFileSync(modelsPath, 'utf-8'));
  } catch (e) {
    console.error(`Error loading models for ${brandSlug}:`, e);
  }
}
---

<Layout title={`${brandName} ECU Documentation`}>
  <main>
    <div class="brand-header">
      {brandLogo && (
        <img src={brandLogo} alt={`${brandName} logo`} class="brand-header-logo" />
      )}
      <div>
        <h1>{brandName} ECU Documentation</h1>
        <p class="brand-subtitle">Engine Control Unit documentation and guides</p>
      </div>
    </div>
    
    <div class="content-grid">
      <!-- Brand Information -->
      <section class="brand-info">
        <h2>About {brandName}</h2>
        <p>Comprehensive ECU documentation for {brandName} vehicles.</p>
        
        {brandUrl && (
          <p>
            <a href={brandUrl} target="_blank" rel="noopener noreferrer" class="external-link">
              Visit {brandName} on AutoEvolution →
            </a>
          </p>
        )}
      </section>
      
      <!-- Automobiles List -->
      <section class="automobiles-section">
        <h2>{brandName} Vehicles</h2>
        {models.length > 0 ? (
          <div class="automobiles-grid">
            {models.map((model) => (
              <div class="automobile-card">
                <h3 class="automobile-name">{model.name}</h3>
                {model.engine_name && (
                  <p class="engine-info">Engine: {model.engine_name}</p>
                )}
                {model.description && (
                  <p class="automobile-description">{model.description}</p>
                )}
                <a href={`/automobiles/${model.slug || model.id}`} class="view-details">
                  View ECU Details →
                </a>
              </div>
            ))}
          </div>
        ) : (
          <div class="no-data">
            <p>No automobile data available for {brandName} yet.</p>
            <p class="help-text">Check back later for ECU documentation updates.</p>
          </div>
        )}
      </section>
    </div>
    
    <!-- Back to brands link -->
    <div class="navigation">
      <a href="/automobiles/brands" class="back-link">← Back to All Brands</a>
    </div>
  </main>
</Layout>