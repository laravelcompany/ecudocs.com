---
import Brands from '@/components/Brands.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import brandsData from '../../../data/brands.json';

const totalBrands = brandsData.length;
const totalModels = 0; // We don't have a global models count easily available yet without scanning folders
---

<BaseLayout
  title={`Vehicle Manufacturers Database | EcuDocs.com`}
  description={`Browse comprehensive ECU documentation across ${totalBrands} global vehicle brands. Select a manufacturer to explore specific models and hardware configurations.`}
  keywords={`automotive brands, vehicle manufacturers, ECU database, car brands, ${brandsData.slice(0, 10).map(b => b[3]).join(', ')}`}
>
  <main class="min-h-screen bg-gray-50 dark:bg-charcoal-900 pb-20">
    <!-- Brands Hero Section -->
    <header class="bg-charcoal-500 py-20 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M0 0 L100 100 L0 100 Z" fill="currentColor"></path>
        </svg>
      </div>
      
      <div class="container mx-auto px-4 relative z-10 text-center">
        <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter leading-none">
          Automotive <span class="text-tomato-500 italic">Manufacturers</span>
        </h1>
        <p class="text-xl text-charcoal-100 max-w-2xl mx-auto mb-10 font-medium">
          Comprehensive ECU documentation across {totalBrands} global vehicle brands. 
          Select a manufacturer to explore specific models and hardware configurations.
        </p>
        
        <div class="flex justify-center gap-8 border-t border-white/10 pt-10 max-w-lg mx-auto">
          <div class="text-center">
             <div class="text-3xl font-black">{totalBrands}</div>
             <div class="text-[10px] font-black uppercase tracking-[0.2em] text-charcoal-300">Total Brands</div>
          </div>
          <div class="text-center">
             <div class="text-3xl font-black">2025</div>
             <div class="text-[10px] font-black uppercase tracking-[0.2em] text-charcoal-300">Catalog Year</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Brands Grid -->
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="bg-white dark:bg-charcoal-800 rounded-3xl p-8 md:p-12 shadow-sm border border-gray-100 dark:border-charcoal-700">
           <div class="flex items-center justify-between mb-12 border-b border-gray-50 dark:border-charcoal-700 pb-8">
              <h2 class="text-2xl font-black text-gray-900 dark:text-white uppercase tracking-tight">Full Manufacturer Index</h2>
              <div class="hidden md:flex items-center gap-2 text-xs font-bold text-gray-400">
                 <span>A-Z Catalog</span>
                 <span class="h-1 w-1 rounded-full bg-gray-300"></span>
                 <span>Global Support</span>
              </div>
           </div>
           
           <!-- The Brands Component handles the grid -->
           <Brands className="opacity-100" />
        </div>
      </div>
    </section>

    <!-- Feature Section -->
    <section class="py-20 bg-charcoal-900 text-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="space-y-4">
             <div class="text-tomato-500">
                <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
             </div>
             <h4 class="text-xl font-black">Fast Integration</h4>
             <p class="text-sm text-charcoal-300 leading-relaxed">Our unified data format ensures that brand-specific hardware configurations map seamlessly to global diagnostic standards.</p>
          </div>
          <div class="space-y-4">
             <div class="text-tomato-500">
                <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
             </div>
             <h4 class="text-xl font-black">Verified Accuracy</h4>
             <p class="text-sm text-charcoal-300 leading-relaxed">Every pinout and technical chart is cross-referenced with manufacturer service bulletins and lab-tested hardware results.</p>
          </div>
          <div class="space-y-4">
             <div class="text-tomato-500">
                <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
             </div>
             <h4 class="text-xl font-black">Daily Updates</h4>
             <p class="text-sm text-charcoal-300 leading-relaxed">We add new models and hardware revisions daily, ensuring you always have the most current technical data for repair.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-24">
      <div class="container mx-auto px-4">
        <div class="bg-tomato-500 rounded-[3rem] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl">
          <div class="absolute -right-20 -top-20 h-64 w-64 bg-white/10 rounded-full"></div>
          <h2 class="text-4xl md:text-5xl font-black mb-8 italic relative z-10">Missing a specific brand or model?</h2>
          <p class="text-lg font-medium mb-12 text-tomato-100 max-w-2xl mx-auto relative z-10">Our engineering team can prioritize documentation for specific commercial or niche manufacturers upon request.</p>
          <a href="/contact" class="inline-flex items-center rounded-2xl bg-charcoal-900 px-10 py-5 text-lg font-black hover:bg-black transition-all shadow-xl relative z-10">
            Request Brand Addition
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>